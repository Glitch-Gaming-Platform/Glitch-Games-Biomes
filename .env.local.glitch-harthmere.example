# Harthmere / Glitch integration.
# Copy these into .env.local for local dev or inject them as server environment variables in production.
GLITCH_API_BASE_URL=https://api.glitch.fun/api
GLITCH_TITLE_ID=42de534c-600f-4228-af9e-b69faef94cce

# Required for the Next.js server-side proxy. Do not commit the real value.
GLITCH_TITLE_TOKEN=

# Optional client-visible title id. This is not secret.
NEXT_PUBLIC_GLITCH_TITLE_ID=42de534c-600f-4228-af9e-b69faef94cce

# Optional: how long an old session can be inactive before a newer login can disconnect it.
GLITCH_IDLE_SESSION_MS=120000

# Optional: cleanup TTL for remembered server sessions in a Node process.
GLITCH_SESSION_TTL_MS=43200000
