
async function assertNoHarthmereCompileOverlay(page) {
  const bodyText = await page.locator("body").innerText({ timeout: 5000 }).catch(() => "");
  const hasCompileError = /Failed to compile|Module build failed|the name `[^`]+` is defined multiple times|defined multiple times|SyntaxError|TypeError:/.test(bodyText);
  if (hasCompileError) {
    throw new Error(`Browser compile/runtime overlay detected before collision helper checks:\n${bodyText.slice(0, 1400)}`);
  }
}
#!/usr/bin/env node
/* HARTHMERE_COLLISION_OVERLAY_SCREENSHOT_AUDIT_V1 */
const fs = require("fs");
const path = require("path");

const root = process.argv[2] || process.cwd();
const url = process.env.HARTHMERE_E2E_URL || "";
const outDir = process.env.HARTHMERE_SCREENSHOT_OUT || path.join(root, "tmp", "harthmere-collision-overlays");
const timeoutMs = Number(process.env.HARTHMERE_E2E_TIMEOUT_MS || 90000);
let ok = true;

function pass(label) { console.log(`OK ${label}`); }
function fail(label, detail) {
  ok = false;
  console.log(`FAIL ${label}`);
  if (detail) for (const line of (Array.isArray(detail) ? detail : String(detail).split("\n")).filter(Boolean)) console.log(`  - ${line}`);
}

console.log("== Harthmere collision overlay screenshot audit tests v1 ==");
console.log(`Root: ${root}`);
console.log(`URL: ${url || "<missing HARTHMERE_E2E_URL>"}`);
console.log(`Output: ${outDir}`);
console.log();

const visual = path.join(root, "src/shared/harthmere/visual_readability.ts");
const assets = path.join(root, "src/client/game/renderers/local_dev/harthmere_assets.ts");
const player = path.join(root, "src/client/game/scripts/player.ts");

for (const file of [visual, assets, player]) {
  if (fs.existsSync(file)) pass(`${path.relative(root, file)} exists`);
  else fail(`${path.relative(root, file)} exists`, `Missing ${file}`);
}

if (!url) {
  fail("live browser URL is provided for overlay audit", "Set HARTHMERE_E2E_URL to the running Harthmere page.");
  console.log("\nRESULT: FAIL (missing live URL)");
  process.exit(1);
}

function resolvePlaywright() {
  for (const candidate of [path.join(root, "node_modules", "playwright"), "playwright", path.join(root, "node_modules", "@playwright/test"), "@playwright/test"]) {
    try { const mod = require(candidate); if (mod.chromium) return mod; } catch (_) {}
  }
  return null;
}

const playwright = resolvePlaywright();
if (!playwright) {
  fail("Playwright is installed for overlay screenshot audit", "Run: npm install --save-dev playwright");
  console.log("\nRESULT: FAIL (missing Playwright)");
  process.exit(1);
}

const viewpoints = [
  { id: "north_gate_fixtures", district: "North Gate", targets: ["obj_flag_large_red", "obj_lamp_ground_large", "obj_lamp_ground_small"] },
  { id: "market_fountain_fixtures", district: "Market Square", targets: ["fountain_round", "fountain_round_detail", "fountain_center", "obj_lamp_ground_small"] },
  { id: "temple_church_fixtures", district: "Temple Green", targets: ["obj_church_iso", "obj_church_base_lower", "obj_church_grave_wall", "obj_church_grave_fence"] },
];

(async () => {
  fs.mkdirSync(outDir, { recursive: true });
  const browser = await playwright.chromium.launch({ headless: process.env.HARTHMERE_E2E_HEADLESS !== "0" });
  const page = await browser.newPage({ viewport: { width: 1600, height: 1000 } });
  page.setDefaultTimeout(timeoutMs);

  try {
    await page.goto(url, { waitUntil: "domcontentloaded", timeout: timeoutMs });
    await page.waitForFunction(() => document.querySelector("canvas"), null, { timeout: timeoutMs }).catch(() => null);
    pass("browser page loaded for overlay audit");

    const hasHelper = await page.evaluate(() => !!(
      globalThis.__harthmereCollisionOverlayAudit?.captureSolidFixtureOverlayReport
      || globalThis.__harthmereTownAudit?.captureSolidFixtureOverlayReport
    ));

    if (!hasHelper) {
      fail("browser exposes collision overlay screenshot audit helper", [
        "Expected window.__harthmereCollisionOverlayAudit.captureSolidFixtureOverlayReport(viewpoints)",
        "or window.__harthmereTownAudit.captureSolidFixtureOverlayReport(viewpoints).",
        "The report must compare visible mesh bounds to player collision proxy bounds for each target fixture.",
      ]);
      await browser.close();
      console.log("\nRESULT: FAIL (missing overlay audit helper)");
      process.exit(1);
    }
    pass("browser exposes collision overlay screenshot audit helper");

    const report = await page.evaluate(async (viewpoints) => {
      const runner = globalThis.__harthmereCollisionOverlayAudit?.captureSolidFixtureOverlayReport
        || globalThis.__harthmereTownAudit?.captureSolidFixtureOverlayReport;
      return await runner(viewpoints, {
        showOverlay: true,
        requireVisibleMesh: true,
        requireCollisionProxy: true,
        maxCenterDeltaMeters: 1.25,
        minProxyCoverageRatio: 0.35,
        maxProxyCoverageRatio: 1.6,
      });
    }, viewpoints);

    await page.screenshot({ path: path.join(outDir, "harthmere-collision-overlay-audit.png"), fullPage: true });
    pass("collision overlay screenshot was captured");

    if (!report || report.ok !== true) {
      const details = (report?.failures || []).map((f) => `${f.viewpoint || f.id || "unknown"}: ${f.message || f.reason || JSON.stringify(f)}`);
      fail("visible imported fixtures have matching player collision overlay proxies", details.length ? details : JSON.stringify(report || null));
    } else {
      pass("visible imported fixtures have matching player collision overlay proxies");
    }
  } catch (error) {
    fail("collision overlay screenshot audit completed without unhandled exception", error.stack || String(error));
  } finally {
    await browser.close().catch(() => null);
  }

  console.log(ok ? "\nRESULT: PASS" : "\nRESULT: FAIL");
  process.exit(ok ? 0 : 1);
})();
