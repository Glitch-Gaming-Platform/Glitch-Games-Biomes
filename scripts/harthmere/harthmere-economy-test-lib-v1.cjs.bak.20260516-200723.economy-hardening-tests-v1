#!/usr/bin/env node
/* eslint-disable no-console */
const fs = require("fs");
const path = require("path");

function createHarness(title) {
  const root = process.argv[2] ? path.resolve(process.argv[2]) : process.cwd();
  let failed = 0;
  function rel(p) { return path.join(root, p); }
  function exists(p) { return fs.existsSync(rel(p)); }
  function read(p) { return fs.readFileSync(rel(p), "utf8"); }
  function ok(condition, label) {
    if (condition) console.log(`OK ${label}`);
    else { failed += 1; console.log(`FAIL ${label}`); }
  }
  function includes(file, needle, label) { ok(read(file).includes(needle), label || `${file} contains ${needle}`); }
  function notIncludes(file, needle, label) { ok(!read(file).includes(needle), label || `${file} does not contain ${needle}`); }
  function matches(file, pattern, label) { ok(pattern.test(read(file)), label || `${file} matches ${pattern}`); }
  function fileExists(file, label) { ok(exists(file), label || `${file} exists`); }
  function done() {
    console.log(`\nRESULT: ${failed === 0 ? "PASS" : "FAIL"}`);
    process.exit(failed === 0 ? 0 : 1);
  }
  console.log(`== ${title} ==`);
  console.log(`Root: ${root}\n`);
  return { root, rel, read, exists, ok, includes, notIncludes, matches, fileExists, done };
}

function inventorySource(h) { return h.read("src/client/components/challenges/LocalDevHarthmereInventorySystem.tsx"); }
function economySource(h) { return h.read("src/client/components/challenges/LocalDevHarthmereEconomySystem.tsx"); }
function vendorSource(h) { return h.read("src/client/components/challenges/LocalDevHarthmereVendorCatalog.ts"); }
function challengeSource(h, name) { return h.read(`src/client/components/challenges/${name}`); }

function extractItemDefinitionBlock(source) {
  const start = source.indexOf("const ITEM_DEFINITIONS");
  const end = source.indexOf("const SPELL_DEFINITIONS");
  if (start < 0 || end < 0 || end <= start) return "";
  return source.slice(start, end);
}

function extractItemBlocks(source) {
  const chunk = extractItemDefinitionBlock(source);
  const ids = [];
  const starts = [];
  const re = /\n\s{2}([a-zA-Z0-9_]+):\s*\{/g;
  let m;
  while ((m = re.exec(chunk))) {
    ids.push(m[1]);
    starts.push(m.index);
  }
  const blocks = new Map();
  for (let i = 0; i < ids.length; i += 1) {
    const start = starts[i];
    const end = i + 1 < ids.length ? starts[i + 1] : chunk.lastIndexOf("\n};");
    blocks.set(ids[i], chunk.slice(start, end));
  }
  return blocks;
}

function itemBlocks(h) { return extractItemBlocks(inventorySource(h)); }
function catalogOffsets(h) {
  const src = vendorSource(h);
  return Array.from(src.matchAll(/^\s{2}(\d+):\s*vendor\(/gm)).map((m) => Number(m[1]));
}
function catalogItemIds(h) {
  const src = vendorSource(h);
  return Array.from(src.matchAll(/itemId:\s*"([^"]+)"/g)).map((m) => m[1]);
}
function itemIds(h) { return Array.from(itemBlocks(h).keys()); }

function assertItemFields(h) {
  const blocks = itemBlocks(h);
  h.ok(blocks.size >= 50, "item catalog has broad MMO coverage");
  for (const [id, block] of blocks.entries()) {
    h.ok(new RegExp(`id:\\s*"${id}"`).test(block), `${id} declares matching id`);
    for (const field of ["name", "category", "subtype", "quality", "icon", "stackable", "maxStack", "bindType", "baseValue", "description"]) {
      h.ok(new RegExp(`${field}:`).test(block), `${id} declares ${field}`);
    }
  }
}

function assertNoDuplicateItemNames(h) {
  const names = new Map();
  for (const [id, block] of itemBlocks(h).entries()) {
    const match = block.match(/name:\s*"([^"]+)"/);
    if (!match) continue;
    const name = match[1];
    if (!names.has(name)) names.set(name, []);
    names.get(name).push(id);
  }
  const duplicates = Array.from(names.entries()).filter(([, ids]) => ids.length > 1);
  h.ok(duplicates.length === 0, `no duplicate display names unless explicitly whitelisted (${duplicates.map(([n, ids]) => `${n}: ${ids.join(",")}`).join("; ")})`);
}

function assertUnifiedVendorCatalog(h) {
  h.fileExists("src/client/components/challenges/LocalDevHarthmereVendorCatalog.ts", "unified vendor catalog module exists");
  const inv = inventorySource(h);
  const eco = economySource(h);
  const cat = vendorSource(h);
  h.includes("src/client/components/challenges/LocalDevHarthmereInventorySystem.tsx", "HARTHMERE_VENDOR_STOCK", "inventory imports unified vendor stock");
  h.includes("src/client/components/challenges/LocalDevHarthmereEconomySystem.tsx", "HARTHMERE_VENDOR_ECONOMY_PROFILES", "economy imports unified vendor profiles");
  h.ok(!/const VENDOR_STOCK:\s*Record<[^]*?=\s*\{/.test(inv), "inventory no longer owns a separate VENDOR_STOCK object literal");
  h.ok(!/const VENDOR_PROFILES:\s*Record<[^]*?=\s*\{/.test(eco), "economy no longer owns a separate VENDOR_PROFILES object literal");
  for (const key of ["stocks", "sells", "buys", "buysCategories", "baseSellModifier", "baseBuyModifier", "goldSupply", "restockHours", "buysStolenGoods", "refusesStolenGoods"]) {
    h.ok(cat.includes(key), `vendor catalog includes ${key}`);
  }
}

module.exports = {
  createHarness,
  inventorySource,
  economySource,
  vendorSource,
  challengeSource,
  itemBlocks,
  itemIds,
  catalogOffsets,
  catalogItemIds,
  assertItemFields,
  assertNoDuplicateItemNames,
  assertUnifiedVendorCatalog,
};
