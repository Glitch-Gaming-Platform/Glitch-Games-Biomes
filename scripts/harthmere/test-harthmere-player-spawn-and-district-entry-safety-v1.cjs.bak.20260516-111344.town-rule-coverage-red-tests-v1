#!/usr/bin/env node
/* eslint-disable no-console */
const path = require("path");
const {
  loadTown,
  makeReporter,
  normalizeDistrict,
  distance2d,
  isSolidUploadedAsset,
  collisionBlocksPlayerLikeRegistry,
} = require("./harthmere-town-rule-test-utils-v1.cjs");

const root = process.argv[2] ? path.resolve(process.argv[2]) : process.cwd();
const report = makeReporter("Harthmere player spawn and district entry safety tests v1", root);
const town = loadTown(root);

const blockers = town.placements.filter((p) => {
  if (p.kind === "A") return false;
  const assetInfo = town.assets.get(p.asset);
  return (isSolidUploadedAsset(assetInfo, p) || collisionBlocksPlayerLikeRegistry(p));
});

const namedEntryPlacements = town.placements.filter((p) => /gate|entry|entrance|door|approach|arrival|plaza|square|road|path|stairs|ramp|service/i.test(`${p.name} ${p.district}`));
report.check("town exposes named entries/approaches for spawn safety audits", namedEntryPlacements.length >= 30, `found ${namedEntryPlacements.length}`);

const entryBlocked = namedEntryPlacements
  .filter((entry) => blockers.some((b) => b !== entry && distance2d(entry, b) < 0.9 && !/door|gate|stairs|ramp|path|road|plaza|square/i.test(`${entry.asset} ${entry.name}`)))
  .map((entry) => `${entry.name || entry.asset} (${entry.asset}) ${entry.district || "Unknown"} line ${entry.line}`);
report.check("named district entries and service approaches do not start inside solid blockers", entryBlocked.length === 0, entryBlocked);

const actorOverEntry = town.placements
  .filter((p) => p.kind === "A")
  .filter((actor) => namedEntryPlacements.some((entry) => distance2d(actor, entry) < 0.65 && /door|entry|entrance|gate|arrival/i.test(`${entry.name} ${entry.district}`)))
  .map((actor) => `${actor.name || actor.asset} (${actor.asset}) too close to entry in ${actor.district || "Unknown"} line ${actor.line}`);
report.check("NPCs and animals do not spawn directly on top of district entries", actorOverEntry.length === 0, actorOverEntry);

const requiredDistricts = ["north_gate", "market_square", "player_services", "copper_kettle", "craftsman_row", "temple_green", "noble_rise", "river_docks", "mudden_ward", "guard_yard", "old_well_underways"];
const missingEntryDistricts = requiredDistricts.filter((district) => !namedEntryPlacements.some((p) => normalizeDistrict(p.district) === district));
report.check("each town district has at least one named entry/approach marker", missingEntryDistricts.length === 0, missingEntryDistricts);

report.finish();
