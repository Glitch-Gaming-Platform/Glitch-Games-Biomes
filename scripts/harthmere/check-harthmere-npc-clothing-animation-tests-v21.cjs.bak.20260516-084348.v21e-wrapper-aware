#!/usr/bin/env node

const path = require("path");
const { spawnSync } = require("child_process");

const root = process.argv[2] || process.cwd();
const tester = path.join(root, "scripts/harthmere/test-harthmere-npc-clothing-animation-v21.cjs");

const result = spawnSync(process.execPath, [tester, root], {
  stdio: "inherit",
});

process.exit(result.status ?? 1);
