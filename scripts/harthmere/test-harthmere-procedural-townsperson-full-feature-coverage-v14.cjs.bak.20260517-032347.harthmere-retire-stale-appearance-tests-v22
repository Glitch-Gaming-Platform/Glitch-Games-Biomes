#!/usr/bin/env node
/* eslint-disable no-console */
const fs = require("fs");
const path = require("path");

const root = process.argv[2] || process.cwd();
const runtimePath = path.join(root, "src/client/game/renderers/local_dev/harthmere_assets.ts");
const schemaPath = path.join(root, "src/shared/harthmere/voxel_faces.ts");

const runtime = fs.readFileSync(runtimePath, "utf8");
const schema = fs.readFileSync(schemaPath, "utf8");

let ok = true;
function check(label, condition, detail) {
  if (condition) {
    console.log(`OK ${label}`);
  } else {
    ok = false;
    console.error(`FAIL ${label}`);
    if (detail) console.error(`     ${detail}`);
  }
}

function bodyOf(source, signature) {
  const start = source.indexOf(signature);
  if (start < 0) return "";
  const open = source.indexOf("{", start);
  if (open < 0) return "";
  let depth = 0;
  for (let i = open; i < source.length; i += 1) {
    if (source[i] === "{") depth += 1;
    if (source[i] === "}") {
      depth -= 1;
      if (depth === 0) return source.slice(start, i + 1);
    }
  }
  return "";
}

const loadAllBody = bodyOf(runtime, "private async loadAll()");
const createTownBody = bodyOf(runtime, "function createProceduralTownsperson(");
const metricsBody = bodyOf(runtime, "function harthmereRuntimeBodyMetrics(");
const headBody = bodyOf(runtime, "function createHarthmereRuntimeVoxelHead(");
const paletteBody = bodyOf(runtime, "function harthmereRuntimePaletteForAppearance(");

const faceFields = [
  "genderIdentity",
  "pronouns",
  "customPronouns",
  "skinTone",
  "faceShape",
  "eyeShape",
  "eyeColor",
  "browStyle",
  "noseStyle",
  "mouthStyle",
  "hairStyle",
  "hairColor",
  "facialHair",
  "cheekStyle",
  "accessory",
];

const visualFaceFields = [
  "skinTone",
  "faceShape",
  "eyeShape",
  "eyeColor",
  "browStyle",
  "noseStyle",
  "mouthStyle",
  "hairStyle",
  "hairColor",
  "facialHair",
  "cheekStyle",
  "accessory",
];

const bodyFields = [
  "bodyType",
  "bodyHeight",
  "shoulderWidth",
  "armLength",
  "legLength",
  "stance",
  "outfitColor",
];

const bodyGeometryFields = [
  "bodyType",
  "bodyHeight",
  "shoulderWidth",
  "armLength",
  "legLength",
  "stance",
];

const clothingSlots = [
  "head",
  "face",
  "torso",
  "legs",
  "hands",
  "feet",
  "back",
  "belt",
  "weapon",
  "shield",
];

check("townsperson placements are forced into procedural path before prototype lookup",
  loadAllBody.includes("createProceduralTownsperson(placement)") &&
  loadAllBody.indexOf("createProceduralTownsperson(placement)") <
    loadAllBody.indexOf("const prototype = this.prototypes.get(placement.asset)"));
check("prototype branch refuses townsperson GLTF path",
  loadAllBody.includes("if (prototype && !isProceduralTownspersonKey(placement.asset))"));
check("procedural townsperson stores full appearance on root",
  createTownBody.includes("root.userData.harthmereAppearance = appearance"));
check("procedural townsperson creates body metrics from shared body schema",
  createTownBody.includes("harthmereRuntimeBodyMetrics(appearance.body)"));
check("procedural townsperson creates actual runtime voxel head from shared face schema",
  createTownBody.includes("createHarthmereRuntimeVoxelHead(appearance"));

for (const field of faceFields) {
  check(`shared face schema includes ${field}`, schema.includes(field));
}
for (const field of visualFaceFields) {
  check(`runtime head uses visual face field ${field}`,
    headBody.includes(`face.${field}`) || headBody.includes(`appearance.face.${field}`),
    `${field} must affect the procedural NPC face/head`);
}

for (const field of bodyFields) {
  check(`shared body schema includes ${field}`, schema.includes(field));
}
for (const field of bodyGeometryFields) {
  check(`runtime body metrics use body field ${field}`,
    metricsBody.includes(`body.${field}`) || createTownBody.includes(`appearance.body.${field}`),
    `${field} must affect procedural body geometry`);
}
check("runtime palette uses outfitColor",
  paletteBody.includes("outfitColor") || createTownBody.includes("outfitColor"));

for (const slot of clothingSlots) {
  check(`shared clothing schema/catalog includes slot ${slot}`,
    schema.includes(`"${slot}"`) || schema.includes(`'${slot}'`) || schema.includes(`${slot}:`));
}

const runtimeClothingCoverage = runtime.toLowerCase();
for (const slot of clothingSlots) {
  check(`runtime clothing path references clothing slot ${slot}`,
    runtimeClothingCoverage.includes(`clothing?.${slot}`) ||
    runtimeClothingCoverage.includes(`clothing.${slot}`) ||
    runtimeClothingCoverage.includes(`appearance.clothing.${slot}`) ||
    runtimeClothingCoverage.includes(`"${slot}"`) ||
    runtimeClothingCoverage.includes(`'${slot}'`),
    `${slot} must be represented by at least one procedural clothing pass`);
}

check("procedural path applies product clothing polish",
  createTownBody.includes("addHarthmereRuntimeProductMinecraftClothingPolishV20("));
check("procedural path applies visible clothing guarantee",
  createTownBody.includes("addHarthmereRuntimeVisibleClothingGuaranteeV22(") ||
  createTownBody.includes("addHarthmereRuntimeAlwaysVisibleNpcClothingV27("));
check("procedural path exposes clothing-key diagnostics",
  runtime.includes("harthmereForceProceduralTownspersonClothingKeysV13") ||
  runtime.includes("harthmereForceProceduralTownspersonClothingKeysV12"));

if (!ok) {
  console.error("RESULT: FAIL");
  process.exit(1);
}
console.log("RESULT: PASS");
