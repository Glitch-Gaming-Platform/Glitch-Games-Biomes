#!/usr/bin/env node
/* eslint-disable no-console */
const fs = require("fs");
const path = require("path");

const root = process.argv[2] || process.cwd();
const wakePath = path.join(root, "src/client/components/WakeUpScreen.tsx");
const cssPath = path.join(root, "src/client/styles/edit_character.css");
const schemaPath = path.join(root, "src/shared/harthmere/voxel_faces.ts");

const wake = fs.readFileSync(wakePath, "utf8");
const css = fs.existsSync(cssPath) ? fs.readFileSync(cssPath, "utf8") : "";
const schema = fs.readFileSync(schemaPath, "utf8");

let ok = true;
function check(label, condition, detail) {
  if (condition) {
    console.log(`OK ${label}`);
  } else {
    ok = false;
    console.error(`FAIL ${label}`);
    if (detail) console.error(`     ${detail}`);
  }
}

function bodyOf(source, signature) {
  const start = source.indexOf(signature);
  if (start < 0) return "";
  const open = source.indexOf("{", start);
  if (open < 0) return "";
  let depth = 0;
  for (let i = open; i < source.length; i += 1) {
    if (source[i] === "{") depth += 1;
    if (source[i] === "}") {
      depth -= 1;
      if (depth === 0) return source.slice(start, i + 1);
    }
  }
  return "";
}

const bodyPreview = bodyOf(wake, "const HarthmereVoxelBodyPreview");
const facePreview = bodyOf(wake, "const HarthmereActualFacePreview");
const optionRow = bodyOf(wake, "const HarthmereFaceOptionRow");
const clothingRow = bodyOf(wake, "const HarthmereClothingOptionRow");

const faceFields = [
  ["genderIdentity", "HARTHMERE_GENDER_OPTIONS"],
  ["pronouns", "HARTHMERE_PRONOUN_OPTIONS"],
  ["customPronouns", "customPronouns"],
  ["skinTone", "HARTHMERE_SKIN_TONES"],
  ["faceShape", "HARTHMERE_FACE_SHAPES"],
  ["eyeShape", "HARTHMERE_EYE_SHAPES"],
  ["eyeColor", "HARTHMERE_EYE_COLORS"],
  ["browStyle", "HARTHMERE_BROW_STYLES"],
  ["noseStyle", "HARTHMERE_NOSE_STYLES"],
  ["mouthStyle", "HARTHMERE_MOUTH_STYLES"],
  ["hairStyle", "HARTHMERE_HAIR_STYLES"],
  ["hairColor", "HARTHMERE_HAIR_COLORS"],
  ["facialHair", "HARTHMERE_FACIAL_HAIR_STYLES"],
  ["cheekStyle", "HARTHMERE_CHEEK_STYLES"],
  ["accessory", "HARTHMERE_FACE_ACCESSORIES"],
];

const bodyFields = [
  ["bodyType", "HARTHMERE_BODY_TYPES"],
  ["bodyHeight", "HARTHMERE_BODY_HEIGHTS"],
  ["shoulderWidth", "HARTHMERE_SHOULDER_WIDTHS"],
  ["armLength", "HARTHMERE_ARM_LENGTHS"],
  ["legLength", "HARTHMERE_LEG_LENGTHS"],
  ["stance", "HARTHMERE_BODY_STANCES"],
  ["outfitColor", "HARTHMERE_OUTFIT_COLORS"],
];

const clothingSlots = [
  "head",
  "face",
  "torso",
  "legs",
  "hands",
  "feet",
  "back",
  "belt",
  "weapon",
  "shield",
];

check("builder uses actual face preview component",
  wake.includes("HarthmereActualFacePreview") &&
  facePreview.includes("<CharacterPreview"));
check("actual face preview uses typed supported preview slot",
  facePreview.includes('makePreviewSlot("appearencePreview")'));
check("actual face preview has unique mesh version key",
  facePreview.includes("actual-face"));
check("actual face preview keeps wearable overrides",
  facePreview.includes("wearableOverrides={wearableOverrides}"));
check("builder option area remains scrollable",
  wake.includes("harthmere-builder-scroll-options") ||
  css.includes("overflow-y: auto") ||
  wake.includes("overflow-y-auto"));
check("builder option row is compact wrapped chips",
  optionRow.includes("harthmere-builder-pill-group") &&
  optionRow.includes("harthmere-builder-chip"));
check("clothing row is compact wrapped chips",
  clothingRow.includes("harthmere-builder-pill-group") ||
  wake.includes('className="harthmere-builder-pill-group"'));

for (const [field, source] of faceFields) {
  check(`shared face schema has ${field}`, schema.includes(field));
  check(`builder renders face field ${field}`,
    wake.includes(`field="${field}"`) || wake.includes(`data-harthmere-builder-field="${field}"`) || wake.includes(field),
    `${field} must be present in WakeUpScreen`);
  if (field !== "customPronouns") {
    check(`builder uses option source for ${field}`,
      wake.includes(source), `${field} should use ${source}`);
    check(`builder updates ${field} through canonical handler`,
      wake.includes(`updateHarthmereBuilderField("${field}"`) ||
      wake.includes(`updateHarthmereBuilderField('${field}'`) ||
      wake.includes(`field="${field}"`),
      `${field} should update through updateHarthmereBuilderField`);
  } else {
    check("custom pronouns input is bound to state",
      wake.includes('data-harthmere-builder-field="customPronouns"') &&
      wake.includes("harthmereFace.customPronouns"));
  }
}

for (const [field, source] of bodyFields) {
  check(`shared body schema has ${field}`, schema.includes(field));
  check(`builder renders body field ${field}`,
    wake.includes(`field="${field}"`) || wake.includes(field),
    `${field} must be present in WakeUpScreen`);
  check(`builder uses option source for ${field}`,
    wake.includes(source), `${field} should use ${source}`);
  check(`builder updates ${field} through canonical handler`,
    wake.includes(`updateHarthmereBuilderField("${field}"`) ||
    wake.includes(`updateHarthmereBuilderField('${field}'`) ||
    wake.includes(`field="${field}"`),
    `${field} should update through updateHarthmereBuilderField`);
  check(`mini body preview reacts to ${field}`,
    bodyPreview.includes(`body.${field}`) ||
    (field === "outfitColor" && bodyPreview.includes("BODY_COLOR_SWATCHES")),
    `${field} must visibly change the body preview`);
}

for (const slot of clothingSlots) {
  check(`shared clothing schema has slot ${slot}`,
    schema.includes(`"${slot}"`) || schema.includes(`'${slot}'`) || schema.includes(`${slot}:`));
  check(`builder clothing UI can render slot ${slot}`,
    wake.includes("HARTHMERE_CLOTHING_SLOTS") &&
    (wake.includes(`"${slot}"`) || wake.includes(`'${slot}'`) || schema.includes(`"${slot}"`) || schema.includes(`'${slot}'`)));
  check(`body/clothing preview references slot ${slot}`,
    bodyPreview.includes(`clothing.${slot}`) ||
    bodyPreview.includes(`clothing?.${slot}`) ||
    bodyPreview.includes(`"${slot}"`) ||
    bodyPreview.includes(`'${slot}'`) ||
    clothingRow.includes("harthmereClothingCatalogForSlot(slot)"),
    `${slot} should affect preview or be represented by clothing row`);
}

check("builder initializes clothing from saved player/body config",
  wake.includes("loadHarthmerePlayerClothingConfig"));
check("builder saves clothing when clothing/body changes",
  wake.includes("saveHarthmerePlayerClothingConfig"));
check("builder persists before entering game",
  wake.includes("startGame") && wake.includes("saveHarthmerePlayerClothingConfig"));
check("builder invalidates preview/resource key when clothing changes",
  wake.includes("harthmereFacePreviewKey") && wake.includes("harthmereClothing"));

if (!ok) {
  console.error("RESULT: FAIL");
  process.exit(1);
}
console.log("RESULT: PASS");
