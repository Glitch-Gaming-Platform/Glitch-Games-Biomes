check(
  "NPC animation clips use non-empty keyframe tracks",
  countMatches(animationClipBody, /new THREE\.[A-Za-z]+KeyframeTrack\(/g) >= 3 ||
    countMatches(animationClipBody, /KeyframeTrack\(/g) >= 3
