#!/usr/bin/env node

const fs = require("fs");
const path = require("path");

const root = process.argv[2] || process.cwd();

const files = {
  faces: path.join(root, "src/shared/harthmere/voxel_faces.ts"),
  npcs: path.join(root, "src/client/game/resources/npcs.ts"),
  assets: path.join(root, "src/client/game/renderers/local_dev/harthmere_assets.ts"),
  player: path.join(root, "src/client/game/resources/player_mesh.ts"),
};

const text = Object.fromEntries(
  Object.entries(files).map(([key, file]) => [key, fs.existsSync(file) ? fs.readFileSync(file, "utf8") : ""])
);

let ok = true;
const failures = [];

function pass(label) {
  console.log(`OK ${label}`);
}

function fail(label, detail = "") {
  ok = false;
  failures.push({ label, detail });
  console.log(`FAIL ${label}${detail ? ` — ${detail}` : ""}`);
}

function check(label, condition, detail = "") {
  if (condition) pass(label);
  else fail(label, detail);
}

function extractFunctionBody(src, functionName) {
  const re = new RegExp(`(?:export\\s+)?function\\s+${functionName}\\s*\\(`);
  const match = re.exec(src);
  if (!match) return null;

  const braceStart = src.indexOf("{", match.index);
  if (braceStart < 0) return null;

  let depth = 0;
  for (let i = braceStart; i < src.length; i += 1) {
    const ch = src[i];
    if (ch === "{") depth += 1;
    if (ch === "}") {
      depth -= 1;
      if (depth === 0) {
        return src.slice(braceStart + 1, i);
      }
    }
  }

  return null;
}

function countMatches(src, regex) {
  return [...src.matchAll(regex)].length;
}

function hasAll(src, needles) {
  return needles.every((needle) => src.includes(needle));
}

function hasAny(src, needles) {
  return needles.some((needle) => src.includes(needle));
}

function catalogIds(src) {
  const ids = new Set();
  for (const match of src.matchAll(/([A-Za-z0-9_]+)\s*:\s*harthmereClothingItem\(/g)) {
    ids.add(match[1]);
  }
  return ids;
}

function missingCatalogIds(ids, required) {
  return required.filter((id) => !ids.has(id));
}

console.log("== Harthmere NPC clothing + animation invariant tests v21 ==");
console.log(`Root: ${root}`);
console.log("");

for (const [key, file] of Object.entries(files)) {
  check(`${key} file exists`, fs.existsSync(file), file);
}

const faces = text.faces;
const npcs = text.npcs;
const assets = text.assets;
const player = text.player;
const ids = catalogIds(faces);

console.log("");
console.log("== Clothing catalog and assignment tests ==");

check(
  "v20 product polish catalog is active",
  faces.includes("harthmere-threejs-clothing-catalog-v20-product-minecraft-polish") ||
    faces.includes("HARTHMERE_PRODUCT_MINECRAFT_POLISH_VERSION")
);

check(
  "product clothing guarantee exists",
  faces.includes("function harthmereEnsureProductMinecraftClothingSetV20")
);

const guaranteeBody = extractFunctionBody(faces, "harthmereEnsureProductMinecraftClothingSetV20") || "";
const appearanceBody = extractFunctionBody(faces, "makeHarthmereNpcAppearanceConfig") || "";
const defaultRoleBody = extractFunctionBody(faces, "defaultHarthmereClothingForRole") || "";

check(
  "generated NPC appearance calls complete clothing guarantee",
  appearanceBody.includes("harthmereEnsureProductMinecraftClothingSetV20")
);

check(
  "animal species are allowed to skip humanoid clothing",
  guaranteeBody.includes('input.species === "animal"') && guaranteeBody.includes("return {}")
);

for (const slot of ["torso", "legs", "feet", "belt"]) {
  check(
    `complete clothing guarantee assigns ${slot}`,
    guaranteeBody.includes(`base.${slot} ??=`),
    `Expected base.${slot} ??= in harthmereEnsureProductMinecraftClothingSetV20`
  );
}

check(
  "default role clothing also has core slots",
  hasAll(defaultRoleBody, ["torso:", "legs:", "feet:", "belt:"])
);

const requiredCatalogIds = [
  "earth_tunic",
  "forest_tunic",
  "river_tunic",
  "ember_tunic",
  "earth_trousers",
  "forest_trousers",
  "river_trousers",
  "ember_trousers",
  "travel_boots",
  "soft_shoes",
  "simple_belt",
  "guard_tabard_armor",
  "guard_scale_vest",
  "guard_greaves",
  "guard_boots",
  "guard_gloves",
  "guard_helmet",
  "shield_round",
  "sword_1handed",
  "hunter_jerkin",
  "hunter_cap",
  "quiver_and_bedroll",
  "bow",
  "work_apron",
  "straw_hat",
  "merchant_coat",
  "ledger_belt",
  "clergy_robe",
  "robe_skirt",
  "bandit_mask",
  "knife_belt",
  "torn_tunic",
  "ragged_shroud",
  "blacksmith_apron",
  "fur_cloak",
  "tool_hammer",
];

const missingRequiredCatalogIds = missingCatalogIds(ids, requiredCatalogIds);
check(
  "catalog contains required clothing item ids",
  missingRequiredCatalogIds.length === 0,
  missingRequiredCatalogIds.join(", ")
);

const roleExpectations = [
  {
    role: "guard",
    source: defaultRoleBody + guaranteeBody,
    required: ["guard_helmet", "guard_greaves", "guard_boots", "guard_gloves", "sword_1handed", "shield_round"],
  },
  {
    role: "hunter",
    source: defaultRoleBody + guaranteeBody,
    required: ["hunter_cap", "hunter_jerkin", "rope_belt", "quiver_and_bedroll", "bow"],
  },
  {
    role: "farmer/worker",
    source: defaultRoleBody + guaranteeBody,
    requiredAnyGroups: [
      ["work_apron", "blacksmith_apron"],
      ["tool_belt", "mud_boots", "straw_hat"],
    ],
  },
  {
    role: "merchant",
    source: defaultRoleBody + guaranteeBody,
    required: ["merchant_coat", "ledger_belt"],
  },
  {
    role: "clergy/scholar",
    source: defaultRoleBody + guaranteeBody,
    requiredAnyGroups: [
      ["clergy_robe", "scholar_robe"],
      ["robe_skirt", "ash_trousers", "river_trousers"],
    ],
  },
  {
    role: "bandit/hostile",
    source: defaultRoleBody + guaranteeBody,
    required: ["bandit_mask", "knife_belt"],
  },
  {
    role: "undead",
    source: defaultRoleBody + guaranteeBody,
    required: ["torn_tunic", "ragged_shroud"],
  },
];

for (const expectation of roleExpectations) {
  if (expectation.required) {
    const missing = expectation.required.filter((needle) => !expectation.source.includes(needle));
    check(`${expectation.role} clothing assignment exists`, missing.length === 0, missing.join(", "));
  }

  for (const group of expectation.requiredAnyGroups || []) {
    check(
      `${expectation.role} clothing assignment has one of ${group.join("/")}`,
      group.some((needle) => expectation.source.includes(needle)),
      `missing any of ${group.join(", ")}`
    );
  }
}

check(
  "unique clothing assignment is deterministic",
  faces.includes("harthmereUniqueNpcClothingSeed") &&
    faces.includes("makeHarthmereNpcUniqueClothingSet") &&
    (faces.includes("pick(") || faces.includes("hash"))
);

check(
  "unique clothing assignment includes role/name/id inputs",
  hasAll(faces, ["roleHint", "name", "id"])
);

console.log("");
console.log("== NPC renderer clothing tests ==");

const npcClothingBody = extractFunctionBody(npcs, "addLocalDevNpcModularClothingDetails") || "";
check(
  "ECS/local-dev NPC clothing renderer exists",
  Boolean(npcClothingBody)
);

check(
  "ECS/local-dev NPC renderer loops assigned clothing slots",
  npcClothingBody.includes("Object.keys(clothing)") && npcClothingBody.includes("const item = clothing[slot]")
);

check(
  "ECS/local-dev NPC renderer queues optional GLTF modelUrl clothing",
  npcClothingBody.includes("queueLocalDevNpcLicensedClothingModelV18")
);

for (const slotPattern of [
  ["torso", /slot\s*===\s*["']torso["']|case\s+["']torso["']|appearance\.clothing\.torso|if \(slot === "torso"\)/],
  ["legs", /slot\s*===\s*["']legs["']|case\s+["']legs["']|appearance\.clothing\.legs|if \(slot === "legs"\)/],
  ["feet", /slot\s*===\s*["']feet["']|case\s+["']feet["']|appearance\.clothing\.feet|if \(slot === "feet"\)/],
  ["belt", /slot\s*===\s*["']belt["']|case\s+["']belt["']|appearance\.clothing\.belt|if \(slot === "belt"\)/],
  ["hands", /slot\s*===\s*["']hands["']|case\s+["']hands["']|appearance\.clothing\.hands|if \(slot === "hands"\)/],
  ["head", /slot\s*===\s*["']head["']|case\s+["']head["']|appearance\.clothing\.head|if \(slot === "head"\)/],
  ["face", /slot\s*===\s*["']face["']|case\s+["']face["']|appearance\.clothing\.face|if \(slot === "face"\)/],
  ["back", /slot\s*===\s*["']back["']|case\s+["']back["']|appearance\.clothing\.back|if \(slot === "back"\)/],
  ["weapon", /slot\s*===\s*["']weapon["']|case\s+["']weapon["']|appearance\.clothing\.weapon|if \(slot === "weapon"\)/],
  ["shield", /slot\s*===\s*["']shield["']|case\s+["']shield["']|appearance\.clothing\.shield|if \(slot === "shield"\)/],
]) {
  const [slot, regex] = slotPattern;
  check(
    `ECS/local-dev NPC renderer handles ${slot} clothing`,
    regex.test(npcClothingBody) || npcClothingBody.includes(`${slot}-`) || npcClothingBody.includes(slot)
  );
}

check(
  "ECS/local-dev NPC renderer records clothing runtime metadata",
  npcs.includes("harthmereModularClothingRuntime") &&
    npcs.includes("harthmereClothingSlots") &&
    npcs.includes("harthmereHiddenBodyZones")
);

check(
  "ECS/local-dev NPC appearance path passes appearance.clothing to renderer",
  npcs.includes("addLocalDevNpcModularClothingDetails(root, appearance.clothing")
);

const runtimeClothingMarker =
  assets.includes("harthmereRuntimeProductMinecraftPolish") ||
  assets.includes("HARTHMERE_RUNTIME_PRODUCT_MINECRAFT_POLISH_VERSION_V20") ||
  assets.includes("addHarthmereRuntimeProductMinecraftPolishV20");

check(
  "runtime/ambient NPC product clothing polish exists",
  runtimeClothingMarker
);

check(
  "runtime/ambient NPC path reads appearance.clothing",
  assets.includes("appearance.clothing") && assets.includes("harthmereClothingSlots")
);

check(
  "runtime/ambient NPC path queues optional GLTF modelUrl clothing",
  assets.includes("queueHarthmereRuntimeLicensedClothingModelsV18") || assets.includes("loadGltf(modelUrl)")
