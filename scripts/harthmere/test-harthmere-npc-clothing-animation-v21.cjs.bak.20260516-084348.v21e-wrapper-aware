console.log("== Player clothing parity tests ==");

check(
  "player clothing renderer still reads assigned clothing slots",
  player.includes("appearance.clothing") && player.includes("Object.keys(clothing)")
);

check(
  "player Three.js clothing renderer is still available",
  player.includes("threeJsVariant") && player.includes("harthmere-player")
);

check(
  "player GLTF modelUrl clothing remains supported",
  player.includes("loadGltf(item.modelUrl)") || (player.includes("modelUrl") && player.includes("loadGltf"))
);

console.log("");
console.log("== NPC animation tests ==");

const animationClipBody = extractFunctionBody(npcs, "makeLocalDevVoxelNpcAnimationClipsV19") || "";
const makeGltfBody = extractFunctionBody(npcs, "makeLocalDevVoxelNpcGltf") || "";

check(
  "NPC animation clip factory exists",
  Boolean(animationClipBody)
);

for (const clipName of ["Idle", "Walk", "Run"]) {
  check(
    `NPC ${clipName} clip is created`,
    animationClipBody.includes(`AnimationClip("${clipName}"`) || animationClipBody.includes(`AnimationClip('${clipName}'`)
  );
