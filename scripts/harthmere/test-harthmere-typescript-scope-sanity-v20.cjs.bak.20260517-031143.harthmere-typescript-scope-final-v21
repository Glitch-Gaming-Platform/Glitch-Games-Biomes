#!/usr/bin/env node
/* eslint-disable no-console */
const fs = require("fs");
const path = require("path");

const root = process.argv[2] || process.cwd();
const runtimePath = path.join(root, "src/client/game/renderers/local_dev/harthmere_assets.ts");
const runtime = fs.readFileSync(runtimePath, "utf8");

let ok = true;
function check(label, condition, detail) {
  if (condition) {
    console.log(`OK ${label}`);
  } else {
    ok = false;
    console.error(`FAIL ${label}`);
    if (detail) console.error(`     ${detail}`);
  }
}

function findEnclosingFunction(source, idx) {
  const candidates = [
    source.lastIndexOf("\nfunction ", idx),
    source.lastIndexOf("\n  function ", idx),
    source.lastIndexOf("\nconst ", idx),
    source.lastIndexOf("\n  const ", idx),
  ];
  let start = Math.max(...candidates);
  if (start === -1) start = source.lastIndexOf("function ", idx);
  if (start === -1) return null;

  const open = source.indexOf("{", start);
  if (open === -1 || open > idx) return null;

  let depth = 0;
  for (let i = open; i < source.length; i += 1) {
    if (source[i] === "{") depth += 1;
    if (source[i] === "}") {
      depth -= 1;
      if (depth === 0) {
        return {
          start,
          open,
          end: i + 1,
          signature: source.slice(start, open),
          body: source.slice(start, i + 1),
        };
      }
    }
  }
  return null;
}

check("face-shape helper exists", runtime.includes("function harthmereRuntimeFaceShapeMetricsV15("));
check("face-shape helper signature uses face parameter",
  runtime.includes("function harthmereRuntimeFaceShapeMetricsV15(face: HarthmereVoxelFaceConfig)"));

const helperIndex = runtime.indexOf("function harthmereRuntimeFaceShapeMetricsV15(");
if (helperIndex >= 0) {
  const helper = findEnclosingFunction(runtime, helperIndex + 8);
  check("helper body does not use appearance.face", helper && !helper.body.includes("appearance.face"));
  check("helper body uses face.faceShape", helper && helper.body.includes("face.faceShape"));
}

check("no stale free faceShapeMetricsV15 property references remain",
  !runtime.includes("faceShapeMetricsV15.width") &&
  !runtime.includes("faceShapeMetricsV15.height") &&
  !runtime.includes("faceShapeMetricsV15.jaw"));

let unsafeAppearanceFaceCount = 0;
let search = 0;
while (true) {
  const idx = runtime.indexOf("appearance.face", search);
  if (idx === -1) break;

  const fn = findEnclosingFunction(runtime, idx);
  if (fn) {
    const beforeUse = runtime.slice(fn.start, idx);
    const hasAppearanceScope =
      fn.signature.includes("appearance:") ||
      fn.signature.includes("(appearance") ||
      fn.signature.includes(" appearance,") ||
      beforeUse.includes("const appearance =") ||
      beforeUse.includes("let appearance =");
    if (!hasAppearanceScope) {
      unsafeAppearanceFaceCount += 1;
      console.error(`UNSAFE appearance.face without appearance scope near index ${idx}`);
    }
  }
  search = idx + "appearance.face".length;
}

check("every appearance.face use has appearance in scope", unsafeAppearanceFaceCount === 0,
  `${unsafeAppearanceFaceCount} unsafe appearance.face references found`);

check("runtime may use either scoped face or scoped appearance for face-shape metrics",
  runtime.includes("harthmereRuntimeFaceShapeMetricsV15(face)") ||
  runtime.includes("harthmereRuntimeFaceShapeMetricsV15(appearance.face)"));

if (!ok) {
  console.error("RESULT: FAIL");
  process.exit(1);
}
console.log("RESULT: PASS");
