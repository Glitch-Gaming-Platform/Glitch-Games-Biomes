#!/usr/bin/env node
/* eslint-disable no-console */
const fs = require("fs");
const path = require("path");
const childProcess = require("child_process");

const root = process.argv[2] || process.cwd();

let ok = true;
function check(label, condition, detail) {
  if (condition) {
    console.log(`OK ${label}`);
  } else {
    ok = false;
    console.error(`FAIL ${label}`);
    if (detail) console.error(`     ${detail}`);
  }
}

const runtimePath = path.join(root, "src/client/game/renderers/local_dev/harthmere_assets.ts");
const runtime = fs.readFileSync(runtimePath, "utf8");

check("runtime no longer uses free faceShapeMetricsV15 variables",
  !runtime.includes("faceShapeMetricsV15.width") &&
  !runtime.includes("faceShapeMetricsV15.height") &&
  !runtime.includes("faceShapeMetricsV15.jaw"));

check("runtime face-shape metric calls use appearance.face where patched",
  runtime.includes("harthmereRuntimeFaceShapeMetricsV15(appearance.face)") ||
  runtime.includes("harthmereRuntimeFaceShapeMetricsV15(face)"));

const tscBin = path.join(root, "node_modules/.bin/tsc");
if (!fs.existsSync(tscBin)) {
  console.log("SKIP full TypeScript gate: node_modules/.bin/tsc not found");
  console.log("RESULT: PASS");
  process.exit(0);
}

console.log("Running full TypeScript gate: npx tsc --noEmit --pretty false");
const result = childProcess.spawnSync(
  "npx",
  ["tsc", "--noEmit", "--pretty", "false"],
  {
    cwd: root,
    env: {
      ...process.env,
      NODE_OPTIONS: process.env.NODE_OPTIONS || "--max-old-space-size=8192",
    },
    encoding: "utf8",
    maxBuffer: 1024 * 1024 * 30,
  }
);

if (result.stdout) process.stdout.write(result.stdout);
if (result.stderr) process.stderr.write(result.stderr);

check("full TypeScript check passes", result.status === 0, `exit code ${result.status}`);

if (!ok) {
  console.error("RESULT: FAIL");
  process.exit(1);
}
console.log("RESULT: PASS");
