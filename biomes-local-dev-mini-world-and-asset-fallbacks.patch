+function toProposedChange(change: Change): ProposedChange {
+  switch (change.kind) {
+    case "create":
+      return { kind: "create", entity: change.entity };
+    case "update":
+      return { kind: "update", entity: change.entity };
+    case "delete":
+      return { kind: "delete", id: change.id };
+  }
+}
