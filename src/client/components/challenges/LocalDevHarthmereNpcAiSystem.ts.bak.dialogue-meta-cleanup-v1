function truthy(value: unknown): boolean { return typeof value === "number" ? value > 0 : Boolean(value); }
export function getHarthmereNpcAiProfile(offset: number): HarthmereNpcRoleAiProfile { const behavior = getHarthmereNpcBehaviorProfile(offset); return HARTHMERE_ROLE_AI_PROFILES[behavior.kind] ?? HARTHMERE_ROLE_AI_PROFILES.civilian; }
export function validateHarthmereNpcAiCoverage() {
  const missingOffsets = HARTHMERE_KNOWN_NPC_OFFSETS.filter((offset) => !getHarthmereNpcAiProfile(offset));
  const missingKinds = Array.from(new Set(HARTHMERE_KNOWN_NPC_OFFSETS.map((offset) => getHarthmereNpcBehaviorProfile(offset).kind))).filter((kind) => !HARTHMERE_ROLE_AI_PROFILES[kind]);
  const layerIds = new Set(HARTHMERE_NPC_AI_STACK.map((layer) => layer.id));
  const missingRequiredLayers = Object.values(HARTHMERE_ROLE_AI_PROFILES).flatMap((profile) => profile.requiredLayers.filter((layer) => !layerIds.has(layer)).map((layer) => `${profile.id}:${layer}`));
  return { missingOffsets, missingKinds, missingRequiredLayers };
}
function keyOf(point: HarthmereVec2): string { return `${point.x},${point.z}`; }
function neighborsOf(point: HarthmereVec2): HarthmereVec2[] { return [{ x: point.x + 1, z: point.z }, { x: point.x - 1, z: point.z }, { x: point.x, z: point.z + 1 }, { x: point.x, z: point.z - 1 }]; }
function heuristic(a: HarthmereVec2, b: HarthmereVec2): number { return Math.abs(a.x - b.x) + Math.abs(a.z - b.z); }

export function planHarthmereGridPath(start: HarthmereVec2, goal: HarthmereVec2, blocked: HarthmereVec2[] = [], maxIterations = 512): HarthmereVec2[] {
  const blockedKeys = new Set(blocked.map(keyOf));
  const open: HarthmereVec2[] = [start];
  const cameFrom = new Map<string, HarthmereVec2>();
  const gScore = new Map<string, number>([[keyOf(start), 0]]);
  const fScore = new Map<string, number>([[keyOf(start), heuristic(start, goal)]]);
  let iterations = 0;
  while (open.length > 0 && iterations < maxIterations) {
    iterations += 1;
    open.sort((a, b) => (fScore.get(keyOf(a)) ?? Infinity) - (fScore.get(keyOf(b)) ?? Infinity));
    const current = open.shift();
    if (!current) break;
    if (current.x === goal.x && current.z === goal.z) {
      const path: HarthmereVec2[] = [current];
      let cursorKey = keyOf(current);
      while (cameFrom.has(cursorKey)) { const previous = cameFrom.get(cursorKey); if (!previous) break; path.unshift(previous); cursorKey = keyOf(previous); }
      return path;
    }
    for (const next of neighborsOf(current)) {
      const nextKey = keyOf(next);
      if (blockedKeys.has(nextKey)) continue;
      const tentative = (gScore.get(keyOf(current)) ?? Infinity) + 1;
      if (tentative >= (gScore.get(nextKey) ?? Infinity)) continue;
      cameFrom.set(nextKey, current); gScore.set(nextKey, tentative); fScore.set(nextKey, tentative + heuristic(next, goal));
      if (!open.some((candidate) => keyOf(candidate) === nextKey)) open.push(next);
    }
  }
  return [start];
}

export function steerHarthmereNpcToward(position: HarthmereVec2, waypoint: HarthmereVec2, obstacles: HarthmereVec2[] = []): HarthmereVec2 {
  const desired = { x: waypoint.x - position.x, z: waypoint.z - position.z };
  let avoid = { x: 0, z: 0 };
  for (const obstacle of obstacles) {
    const dx = position.x - obstacle.x; const dz = position.z - obstacle.z; const distanceSq = dx * dx + dz * dz;
    if (distanceSq > 0 && distanceSq <= 4) avoid = { x: avoid.x + dx / distanceSq, z: avoid.z + dz / distanceSq };
  }
  const combined = { x: desired.x + avoid.x * 2, z: desired.z + avoid.z * 2 };
  const mag = Math.hypot(combined.x, combined.z) || 1;
  return { x: combined.x / mag, z: combined.z / mag };
}

export function runHarthmereBehaviorTree(node: HarthmereBehaviorTreeNode, blackboard: HarthmereNpcAiBlackboard, visited: string[] = []): HarthmereBehaviorTreeResult {
  visited.push(node.id);
  if (node.kind === "condition") return { status: truthy(blackboard[node.condition ?? "isDead"]) ? "success" : "failure", visited };
  if (node.kind === "action") return { status: "success", action: node.action, visited };
  const children = node.children ?? [];
  if (node.kind === "selector") { for (const child of children) { const result = runHarthmereBehaviorTree(child, blackboard, visited); if (result.status === "success" || result.status === "running") return result; } return { status: "failure", visited }; }
  if (node.kind === "sequence") { let selectedAction: string | undefined; for (const child of children) { const result = runHarthmereBehaviorTree(child, blackboard, visited); selectedAction = result.action ?? selectedAction; if (result.status !== "success") return { ...result, action: selectedAction }; } return { status: "success", action: selectedAction, visited }; }
  return { status: "failure", visited };
}

export function transitionHarthmereNpcState(offset: number, blackboard: HarthmereNpcAiBlackboard): HarthmereNpcAiState {
  const kind = getHarthmereNpcAiProfile(offset).kind;
  const hour = blackboard.hour ?? new Date().getHours();
  if (blackboard.isDead) return "dead";
  if (blackboard.isStunned) return "investigating";
  if ((blackboard.isSleeping || hour >= 22 || hour < 5) && !blackboard.dangerLevel && !blackboard.playerWantsTrade && !blackboard.hostileVisible) return "sleeping";
  if ((blackboard.dangerLevel ?? 0) >= 80 && kind !== "guard" && kind !== "creature") return "fleeing";
  if (blackboard.hostileVisible && (kind === "guard" || kind === "creature")) return "combat";
  if (blackboard.crimeWitnessed && kind === "guard") return "investigating";
  if (blackboard.criminalPlayerNearby && kind === "thief") return "helping_criminal";
  if (blackboard.patientNearby && kind === "priest") return "healing";
  if (blackboard.playerWantsTrade && ["merchant", "craftsman", "service", "thief"].includes(kind)) return "trading";
  if (blackboard.dialogueRequested || blackboard.playerNearby) return "talking";
  if (kind === "guard") return "patrolling";
  return "working";
}

export function scoreHarthmereNpcUtilityOptions(offset: number, blackboard: HarthmereNpcAiBlackboard): HarthmereUtilityOption[] {
  const kind = getHarthmereNpcAiProfile(offset).kind;
  const danger = blackboard.dangerLevel ?? 0;
  const shopOpen = blackboard.shopOpen ? 1 : 0;
  const customer = blackboard.customerNearby || blackboard.playerWantsTrade ? 1 : 0;
  const legal = blackboard.legalStanding ?? 0;
  const likeability = blackboard.likeability ?? 0;
  const inventoryPressure = blackboard.inventoryPressure ?? 0;
  const crime = blackboard.crimeWitnessed ? 1 : 0;
  const options: HarthmereUtilityOption[] = [];
  if (["merchant", "craftsman", "service"].includes(kind)) { options.push({ id: "sell_goods", score: 20 + shopOpen * 45 + customer * 30 + Math.max(0, likeability) / 500, reason: "shop open and customer nearby" }); options.push({ id: "buy_goods", score: 15 + customer * 20 + Math.max(0, inventoryPressure), reason: "customer may sell useful goods" }); options.push({ id: "restock", score: 10 + inventoryPressure * 2 + (blackboard.supplierAvailable ? 25 : 0), reason: "stock pressure and supplier access" }); options.push({ id: "call_guards", score: danger + crime * 50 + Math.max(0, -legal) / 250, reason: "protect lawful stock" }); }
  if (kind === "guard") { options.push({ id: "patrol", score: 35 + shopOpen * 10, reason: "guard route duty" }); options.push({ id: "inspect", score: crime * 45 + Math.max(0, -legal) / 150, reason: "crime and bad legal standing" }); options.push({ id: "call_guards", score: danger + crime * 60, reason: "threat requires backup" }); options.push({ id: "arrest", score: crime * 70 + Math.max(0, -legal) / 100, reason: "serious legal response" }); }
  if (kind === "thief") { options.push({ id: "help_criminal", score: (blackboard.criminalPlayerNearby ? 60 : 0) + Math.max(0, -legal) / 200, reason: "criminal contact opportunity" }); options.push({ id: "fence_goods", score: customer * 35 + Math.max(0, -legal) / 300, reason: "stolen-goods economy" }); options.push({ id: "avoid_guards", score: Math.max(0, legal) / 200 + crime * 50 + danger, reason: "avoid lawful attention" }); }
  if (kind === "priest") { options.push({ id: "heal_patient", score: (blackboard.patientNearby ? 70 : 0) + danger * 0.25, reason: "patient care priority" }); options.push({ id: "protect_vulnerable", score: danger + crime * 40, reason: "protect vulnerable people" }); options.push({ id: "condemn_temple_theft", score: crime * 50 + Math.max(0, -legal) / 200, reason: "temple trust broken" }); }
  if (kind === "noble") { options.push({ id: "judge_status", score: Math.max(0, blackboard.notoriety ?? 0) / 200 + customer * 20, reason: "status and leverage" }); options.push({ id: "summon_guard", score: danger + crime * 45, reason: "authority protects itself" }); options.push({ id: "audit_tax", score: 30 + shopOpen * 5, reason: "civic wealth and status" }); }
  if (kind === "peasant" || kind === "civilian") { options.push({ id: "work_route", score: 35 + shopOpen * 10, reason: "daily work matters" }); options.push({ id: "flee", score: danger + Math.max(0, -likeability) / 100, reason: "fear and self-preservation" }); options.push({ id: "call_guards", score: crime * 35 + danger * 0.5, reason: "ordinary people seek help" }); }
  if (kind === "creature") { options.push({ id: "guard_lair", score: 35 + danger * 0.2, reason: "territory instinct" }); options.push({ id: "attack_intruder", score: (blackboard.hostileVisible ? 60 : 0) + danger * 0.6, reason: "threat in territory" }); options.push({ id: "retreat_to_den", score: danger * 0.8 + (blackboard.healthRatio !== undefined && blackboard.healthRatio < 0.35 ? 50 : 0), reason: "survival instinct" }); }
  options.push({ id: "idle_or_patrol", score: 5, reason: "safe fallback" });
  return options.sort((a, b) => b.score - a.score);
}

