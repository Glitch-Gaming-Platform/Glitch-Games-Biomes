  { id: "treat_patient", cost: 2, preconditions: { hasMedicine: true, atPatient: true }, effects: { patientHealed: true } },
];

function worldMatches(world: HarthmereGoapWorldState, state: HarthmereGoapWorldState): boolean { return Object.entries(state).every(([key, value]) => world[key] === value); }
function applyEffects(world: HarthmereGoapWorldState, effects: HarthmereGoapWorldState): HarthmereGoapWorldState { return { ...world, ...effects }; }

export function planHarthmereNpcGoal(goal: HarthmereGoapWorldState, start: HarthmereGoapWorldState = {}, actions = HARTHMERE_DEFAULT_GOAP_ACTIONS, maxDepth = 6): string[] {
  const queue: Array<{ world: HarthmereGoapWorldState; plan: string[]; cost: number }> = [{ world: start, plan: [], cost: 0 }];
  const seen = new Set<string>();
  while (queue.length > 0) {
    queue.sort((a, b) => a.cost - b.cost);
    const current = queue.shift();
    if (!current) break;
    if (worldMatches(current.world, goal)) return current.plan;
    if (current.plan.length >= maxDepth) continue;
    const signature = JSON.stringify(current.world) + current.plan.join(">");
    if (seen.has(signature)) continue;
    seen.add(signature);
    for (const goapAction of actions) if (worldMatches(current.world, goapAction.preconditions)) queue.push({ world: applyEffects(current.world, goapAction.effects), plan: [...current.plan, goapAction.id], cost: current.cost + goapAction.cost });
  }
  return [];
}

export function createEmptyHarthmereNpcMemory(now = Date.now()): HarthmereNpcMemory { return { visibleEnemies: [], heardSounds: [], nearbyItems: [], nearbyPlayers: [], dangerLevel: 0, recentTradePartnerIds: [], reputationByPlayer: {}, witnessedCrimes: [], lastUpdatedAt: now }; }
function pushUnique<T>(items: T[], value: T, limit = 12): T[] { const next = [value, ...items.filter((item) => item !== value)]; return next.slice(0, limit); }

export function updateHarthmereNpcPerceptionMemory(memory: HarthmereNpcMemory, events: HarthmerePerceptionEvent[], now = Date.now()): HarthmereNpcMemory {
  let next: HarthmereNpcMemory = { ...memory, lastUpdatedAt: now };
  for (const event of events) {
    if (event.type === "see_enemy" && event.entityId) next = { ...next, visibleEnemies: pushUnique(next.visibleEnemies, event.entityId), lastSeenEnemyPosition: event.position ?? next.lastSeenEnemyPosition, dangerLevel: Math.max(next.dangerLevel, event.danger ?? 35) };
    if (event.type === "hear_sound") next = { ...next, heardSounds: [event, ...next.heardSounds].slice(0, 10), dangerLevel: Math.max(next.dangerLevel, event.danger ?? 10) };
    if (event.type === "see_item" && event.itemId) next = { ...next, nearbyItems: pushUnique(next.nearbyItems, event.itemId) };
    if (event.type === "see_player" && event.playerId) next = { ...next, nearbyPlayers: pushUnique(next.nearbyPlayers, event.playerId) };
    if (event.type === "attacked_by" && event.entityId) next = { ...next, attackerId: event.entityId, dangerLevel: Math.max(next.dangerLevel, event.danger ?? 90) };
    if (event.type === "crime_witnessed") next = { ...next, witnessedCrimes: [event, ...next.witnessedCrimes].slice(0, 10), dangerLevel: Math.max(next.dangerLevel, event.danger ?? 55) };
    if (event.type === "trade" && event.playerId) next = { ...next, recentTradePartnerIds: pushUnique(next.recentTradePartnerIds, event.playerId) };
    if (event.type === "conversation" && event.playerId) next = { ...next, lastConversationAt: event.timestamp ?? now, reputationByPlayer: { ...next.reputationByPlayer, [event.playerId]: (next.reputationByPlayer[event.playerId] ?? 0) + (event.reputationDelta ?? 0) } };
  }
  return next;
}

function goalForAction(actionId: string): HarthmereGoapWorldState | undefined { if (actionId === "restock") return { shopRestocked: true }; if (actionId === "call_guards" || actionId === "arrest") return { crimeReported: true }; if (actionId === "heal_patient") return { patientHealed: true }; if (actionId === "repair_item" || actionId === "repair_fence") return { buildingRepaired: true }; return undefined; }

export function chooseHarthmereNpcAiDecision(offset: number, blackboard: HarthmereNpcAiBlackboard = {}): HarthmereNpcAiDecision {
  const aiProfile = getHarthmereNpcAiProfile(offset);
  const route = getHarthmereNpcRouteForHour(offset, blackboard.hour);
  const state = transitionHarthmereNpcState(offset, blackboard);
  const tree = runHarthmereBehaviorTree(aiProfile.behaviorTree, { ...blackboard, npcKind: aiProfile.kind, isDead: state === "dead" || blackboard.isDead, dangerLevel: state === "fleeing" ? Math.max(blackboard.dangerLevel ?? 0, 90) : blackboard.dangerLevel });
  const utility = scoreHarthmereNpcUtilityOptions(offset, blackboard)[0] ?? { id: tree.action ?? "idle_or_patrol", score: 0, reason: "fallback" };
  const goal = goalForAction(utility.id);
  const plan = goal ? planHarthmereNpcGoal(goal) : undefined;
  const path = blackboard.position && blackboard.destination ? planHarthmereGridPath(blackboard.position, blackboard.destination, blackboard.blocked ?? []) : undefined;
  return { offset, profileId: aiProfile.id, state, action: utility.id || tree.action || "idle_or_patrol", utilityScore: utility.score, routeAnchor: route?.anchor, path, plan, roleLine: aiProfile.roleFacingLine, debugReason: `${state}:${utility.reason}:${tree.visited.join("/")}` };
}


export async function chooseHarthmereNpcAiDecisionWithThirdParty(offset: number, blackboard: HarthmereNpcAiBlackboard = {}): Promise<HarthmereNpcAiDecision> {
  const base = chooseHarthmereNpcAiDecision(offset, blackboard);
  const aiProfile = getHarthmereNpcAiProfile(offset);
  const statuses = await getHarthmereThirdPartyAiAdapterStatus();
  const thirdPartyStatus = Object.fromEntries(statuses.map((status) => [status.provider, status.installed]));
  const providers = statuses.filter((status) => status.installed).map((status) => status.provider);

  const pathResult = blackboard.position && blackboard.destination
    ? await planHarthmereNpcPathViaThirdParty({
        start: blackboard.position,
        goal: blackboard.destination,
        blocked: blackboard.blocked ?? [],
        fallbackPath: base.path,
      })
    : undefined;

  const behaviorResult = await runHarthmereBehaviorTreeViaBehavior3({
    tree: aiProfile.behaviorTree,
    blackboard: { ...blackboard, npcKind: aiProfile.kind },
    fallback: () => runHarthmereBehaviorTree(aiProfile.behaviorTree, { ...blackboard, npcKind: aiProfile.kind }),
  });

  const steeringResult = blackboard.position && blackboard.destination
    ? await steerHarthmereNpcViaYuka({ from: blackboard.position, to: blackboard.destination })
    : undefined;

  const usedProviders = Array.from(new Set([
    ...providers,
    pathResult?.provider,
    behaviorResult.provider,
    steeringResult?.provider,
  ].filter(Boolean))) as HarthmereThirdPartyAiProvider[];

  return {
    ...base,
    path: pathResult?.path ?? base.path,
    action: behaviorResult.action ?? base.action,
    thirdPartyProviders: usedProviders,
    thirdPartyStatus,
    debugReason: `${base.debugReason}:thirdParty=${usedProviders.join(",")}:path=${pathResult?.reason ?? "none"}:tree=${behaviorResult.reason}:steer=${steeringResult?.reason ?? "none"}`,
  };
}

