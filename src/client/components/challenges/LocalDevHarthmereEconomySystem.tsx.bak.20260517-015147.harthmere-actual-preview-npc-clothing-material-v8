function contributeGoldToProject(projectId: string, amount: number) {
  let economy = readHarthmereEconomyState();
  const project = economy.town.activeProjects.find(
    (entry) => entry.id === projectId,
  );
  if (!project || project.completed) {
    return;
  }
  const needed = Math.max(0, project.requiredGold - project.contributedGold);
  const contribution = Math.min(amount, needed);
  if (contribution <= 0) {
    return;
  }
  if (
    !adjustGold(
      -contribution,
      "Town Project",
      `${project.name}: contributed ${contribution} gold.`,
    )
  ) {
    return;
  }
  economy = readHarthmereEconomyState();
  const projects = economy.town.activeProjects.map((entry) => {
    if (entry.id !== projectId) {
      return entry;
    }
    return { ...entry, contributedGold: entry.contributedGold + contribution };
  });
  economy = finishProjectsIfComplete({
    ...economy,
    town: {
      ...economy.town,
      wealth: clamp(economy.town.wealth + 1, 0, 100),
      activeProjects: projects,
    },
  });
  writeHarthmereEconomyState(
    appendEconomyLog(
      economy,
      "project",
      "Town Project Contribution",
      `${project.name} received ${contribution} gold. Town projects are major voluntary sinks that change Harthmere's economy.`,
      -contribution,
    ),
  );
  applyHarthmereReputationChange({
    label: "Town Project Support",
    detail: `Contributed to ${project.name}.`,
    scope: "harthmere",
    harthmere: { likeability: 35, notoriety: 8 },
  });
}

function contributeMaterialToProject(
  projectId: string,
  itemId: string,
  amount: number,
) {
  let inventory = readHarthmereInventoryState();
  let economy = readHarthmereEconomyState();
  const project = economy.town.activeProjects.find(
    (entry) => entry.id === projectId,
  );
  const item = itemData(itemId);
  if (!project || !item || project.completed) {
    return;
  }
  const required = project.requiredMaterials[itemId] ?? 0;
  const already = project.contributedMaterials[itemId] ?? 0;
  const needed = Math.max(0, required - already);
  const available = inventory.materialStorage[itemId] ?? 0;
  const contribution = Math.min(amount, needed, available);
  if (contribution <= 0) {
    writeHarthmereInventoryState(
      appendInventoryLog(
        inventory,
        "No Project Materials",
        `${project.name} still needs ${item.name}, but none is available in material storage.`,
      ),
    );
    return;
  }
  inventory = appendInventoryLog(
    {
      ...inventory,
      materialStorage: {
        ...inventory.materialStorage,
        [itemId]: available - contribution,
      },
    },
    "Town Project Materials",
    `${item.name} x${contribution} contributed to ${project.name}.`,
  );
  writeHarthmereInventoryState(inventory);
  economy = readHarthmereEconomyState();
  const projects = economy.town.activeProjects.map((entry) => {
    if (entry.id !== projectId) {
      return entry;
    }
    return {
      ...entry,
      contributedMaterials: {
        ...entry.contributedMaterials,
        [itemId]: (entry.contributedMaterials[itemId] ?? 0) + contribution,
      },
    };
  });
  economy = finishProjectsIfComplete({
    ...economy,
    town: {
      ...economy.town,
      wealth: clamp(economy.town.wealth + 1, 0, 100),
      activeProjects: projects,
    },
  });
  writeHarthmereEconomyState(
    appendEconomyLog(
      economy,
      "project",
      "Project Materials",
      `${item.name} x${contribution} moved from material storage into ${project.name}.`,
    ),
  );
}

function finishProjectsIfComplete(state: HarthmereEconomyState) {
  let changed = false;
  const activeProjects = state.town.activeProjects.map((project) => {
    const goldDone = project.contributedGold >= project.requiredGold;
    const materialsDone = Object.entries(project.requiredMaterials).every(
      ([itemId, required]) =>
        (project.contributedMaterials[itemId] ?? 0) >= required,
    );
    if (!project.completed && goldDone && materialsDone) {
      changed = true;
      return { ...project, completed: true };
    }
    return project;
  });
  if (!changed) {
    return { ...state, town: { ...state.town, activeProjects } };
  }
  return appendEconomyLog(
    {
      ...state,
      town: {
        ...state.town,
        activeProjects,
        wealth: clamp(state.town.wealth + 8, 0, 100),
        security: clamp(state.town.security + 6, 0, 100),
        crimeRate: clamp(state.town.crimeRate - 4, 0, 100),
        activeShortages: state.town.activeShortages.filter(
          (shortage) => shortage !== "medicine" && shortage !== "ore",
        ),
      },
    },
    "project",
    "Town Project Complete",
    "A Harthmere town project was completed. Wealth, security, and market access improved.",
  );
}

