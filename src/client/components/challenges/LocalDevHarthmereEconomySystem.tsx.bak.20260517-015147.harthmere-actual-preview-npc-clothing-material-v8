function appendInventoryLog(
  state: HarthmereInventoryState,
  action: string,
  detail: string,
) {
  return {
    ...state,
    recent: [makeInventoryLogEntry(action, detail), ...state.recent].slice(0, 18),
  };
}

function setGold(
  state: HarthmereInventoryState,
  gold: number,
  action: string,
  detail: string,
) {
  return appendInventoryLog(
    {
      ...state,
      wallet: {
        ...state.wallet,
        gold: Math.max(0, Math.round(gold)),
      },
    },
    action,
    detail,
  );
}

function adjustGold(amount: number, action: string, detail: string): boolean {
  const state = readHarthmereInventoryState();
  const current = state.wallet.gold ?? 0;
  const nextGold = current + amount;
  if (nextGold < 0) {
    writeHarthmereInventoryState(
      appendInventoryLog(
        state,
        "Not Enough Gold",
        `${detail} Need ${Math.abs(amount)} gold, but you have ${current}.`,
      ),
    );
    return false;
  }
  writeHarthmereInventoryState(setGold(state, nextGold, action, detail));
  return true;
}

function itemData(itemId: string) {
  return ECONOMY_ITEMS[itemId];
}

function reputationPriceModifier() {
  const reputation = readHarthmereReputationState().regions.harthmere;
  const like = reputation.likeability;
  const legal = reputation.legal;
  let modifier = 1;

  if (like >= 5000) modifier -= 0.12;
  else if (like >= 2000) modifier -= 0.07;
  else if (like >= 500) modifier -= 0.03;
  else if (like <= -5000) modifier += 0.35;
  else if (like <= -2000) modifier += 0.2;
  else if (like <= -500) modifier += 0.08;

  if (legal >= 5000) modifier -= 0.06;
  else if (legal >= 2000) modifier -= 0.03;
  else if (legal <= -5000) modifier += 0.25;
  else if (legal <= -2000) modifier += 0.12;

  return clamp(modifier, 0.65, 1.8);
}

function buyPriceModifier() {
  const reputation = readHarthmereReputationState().regions.harthmere;
  const like = reputation.likeability;
  if (like >= 5000) return 1.25;
  if (like >= 2000) return 1.15;
  if (like >= 500) return 1.05;
  if (like <= -5000) return 0.6;
  if (like <= -2000) return 0.75;
  if (like <= -500) return 0.9;
  return 1;
}

function legalAccessBlocked(vendor: VendorEconomyProfile) {
  const legal = readHarthmereReputationState().regions.harthmere.legal;
  return vendor.refusesStolenGoods && legal <= -5000;
}

function townSupplyModifier(
  state: HarthmereEconomyState,
  item: EconomyItemData,
) {
  let modifier = 1;
  if (item.demandTags.includes("food")) {
    modifier *= state.town.foodSupply >= 70 ? 0.9 : 1.25;
  }
  if (item.demandTags.includes("medicine")) {
    modifier *= state.town.medicineSupply >= 70 ? 0.92 : 1.35;
  }
  if (
    item.demandTags.includes("blacksmithing") ||
    item.demandTags.includes("weapons") ||
    item.demandTags.includes("armor")
  ) {
    modifier *= state.town.oreSupply >= 60 ? 0.9 : 1.3;
  }
  if (state.town.activeShortages.some((tag) => item.demandTags.includes(tag))) {
    modifier *= 1.2;
  }
  if (state.town.activeSurpluses.some((tag) => item.demandTags.includes(tag))) {
    modifier *= 0.88;
  }
  return clamp(modifier, 0.6, 2.2);
}

function vendorPrice(
  vendor: VendorEconomyProfile,
  itemId: string,
  quantity: number,
  mode: "sell_to_player" | "buy_from_player",
) {
  const economy = readHarthmereEconomyState();
  const item = itemData(itemId);
  if (!item) {
    return 0;
  }
  const supply = townSupplyModifier(economy, item);
  const scarcity = item.tier >= 2 ? 1.1 : 1;
  if (mode === "sell_to_player") {
    return Math.max(
      1,
      Math.round(
        item.baseValue *
          quantity *
          vendor.baseSellModifier *
          supply *
          scarcity *
          reputationPriceModifier(),
      ),
    );
  }
  return Math.max(
    1,
    Math.round(
      item.baseValue *
        quantity *
        vendor.baseBuyModifier *
        buyPriceModifier() *
        (2 - supply) *
        0.95,
    ),
  );
}

function activeListings(state: HarthmereEconomyState) {
