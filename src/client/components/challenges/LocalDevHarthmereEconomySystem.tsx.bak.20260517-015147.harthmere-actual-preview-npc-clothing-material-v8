  );
}

function hasStorageForPurchase(itemId: string, quantity: number) {
  const state = readHarthmereInventoryState();
  const item = itemData(itemId);
  if (!item) {
    return false;
  }
  if (item.category === "crafting_material") {
    return true;
  }
  const existing = state.backpack.items.find((instance) => {
    return (
      instance.itemId === itemId &&
      instance.quantity + quantity <= item.stackSize
    );
  });
  return (
    Boolean(existing) || state.backpack.items.length < state.backpack.maxSlots
  );
}

function buyEconomyItem(offset: number, itemId: string, quantity: number) {
  if (!claimHarthmereLocalDevRapidAction(`economy:buy:${offset}:${itemId}:${quantity}`, 650)) {
    return;
  }
  const vendor = VENDOR_PROFILES[offset];
  const item = itemData(itemId);
  if (!vendor || !item) {
    return;
  }
  if (legalAccessBlocked(vendor)) {
    recordHarthmereEconomicEvent(
      "warning",
      "Service Refused",
      `${vendor.name} refuses service while your Harthmere legal standing is outlaw-level. Try a fence or repair your legal standing.`,
    );
    return;
  }
  if (!hasStorageForPurchase(itemId, quantity)) {
    recordHarthmereEconomicEvent(
      "warning",
      "Inventory Full",
      `${item.name} was not bought because there is no safe storage space. The economy system blocks purchases instead of deleting items.`,
    );
    return;
  }
  const price = vendorPrice(vendor, itemId, quantity, "sell_to_player");
  if (
    !adjustGold(
      -price,
      "Vendor Purchase",
