function postFirstSellableItemToAuction() {
  if (!claimHarthmereLocalDevRapidAction("economy:post-auction", 650)) {
    return;
  }
  let inventory = readHarthmereInventoryState();
  const candidate = inventory.backpack.items.find((item) => {
    const economy = itemData(item.itemId);
    return economy?.auctionable && !item.locked && !item.bound && !item.stolen;
  });
  if (!candidate) {
    writeHarthmereInventoryState(
      appendInventoryLog(
        inventory,
        "No Auction Item",
        "No unlocked, unbound, non-stolen auctionable backpack item was found.",
      ),
    );
    return;
  }
  const economyItem = itemData(candidate.itemId)!;
  const quantity = Math.min(
    candidate.quantity,
    economyItem.stackSize > 1 ? 5 : 1,
  );
  const listingFee = Math.max(
    1,
    Math.round(economyItem.baseValue * quantity * 0.03),
  );
  if ((inventory.wallet.gold ?? 0) < listingFee) {
    writeHarthmereInventoryState(
      appendInventoryLog(
        inventory,
        "Cannot List Auction",
        `Listing ${economyItem.name} costs ${listingFee} gold.`,
      ),
    );
    return;
  }

  const removed = removeBackpackItemForSale(
    inventory,
    candidate.itemId,
    quantity,
  );
  inventory = appendInventoryLog(
    {
      ...removed.state,
      wallet: {
        ...removed.state.wallet,
        gold: (removed.state.wallet.gold ?? 0) - listingFee,
      },
    },
    "Auction Listed",
    `${economyItem.name} x${removed.removed} moved into auction escrow. Listing fee: ${listingFee} gold.`,
  );
  writeHarthmereInventoryState(inventory);

  const economy = readHarthmereEconomyState();
  const unitPrice = Math.max(1, Math.round(economyItem.baseValue * 1.35));
  const listing: AuctionListing = {
    listingId: `auction-player-${Date.now()}`,
    sellerId: "local-player",
    sellerName: "You",
    itemId: candidate.itemId,
    quantity: removed.removed,
    unitPrice,
    totalPrice: unitPrice * removed.removed,
    listingFee,
    saleTaxPercent: 8,
    createdAt: now(),
    expiresAt: now() + 2 * 24 * 60 * 60 * 1000,
    status: "active",
    playerOwned: true,
  };
  writeHarthmereEconomyState(
    appendEconomyLog(
      {
        ...economy,
        auctionListings: [listing, ...economy.auctionListings].slice(0, 20),
      },
      "auction",
      "Auction Listed",
      `${economyItem.name} x${removed.removed} listed at ${unitPrice} gold each. Auction fees prevent spam and remove currency.`,
      -listingFee,
    ),
  );
}

function settleOldestPlayerAuction() {
  if (!claimHarthmereLocalDevRapidAction("economy:settle-auction", 650)) {
    return;
  }
  let economy = readHarthmereEconomyState();
  const listing = economy.auctionListings.find(
    (entry) => entry.playerOwned && entry.status === "active",
  );
  if (!listing) {
    recordHarthmereEconomicEvent(
      "warning",
      "No Player Auction",
      "No active player-owned auction listing is waiting to settle.",
    );
    return;
  }
  const tax = Math.round(listing.totalPrice * (listing.saleTaxPercent / 100));
  const payout = listing.totalPrice - tax;
  adjustGold(
    payout,
    "Auction Sale",
    `${itemData(listing.itemId)?.name ?? listing.itemId} sold at auction. Net payout: ${payout} gold after ${tax} tax.`,
  );
  economy = readHarthmereEconomyState();
  writeHarthmereEconomyState(
    appendEconomyLog(
      {
        ...economy,
        auctionListings: economy.auctionListings.map((entry) =>
          entry.listingId === listing.listingId
            ? { ...entry, status: "sold" }
            : entry,
        ),
        priceHistory: {
          ...economy.priceHistory,
          [listing.itemId]: [
            ...(economy.priceHistory[listing.itemId] ?? []),
            listing.unitPrice,
          ].slice(-12),
        },
      },
      "auction",
      "Auction Sale Settled",
      `${listing.sellerName}'s ${itemData(listing.itemId)?.name ?? listing.itemId} listing sold. ${tax} gold left the economy as tax.`,
      payout,
    ),
  );
}

function upgradeBankSpace() {
  if (!claimHarthmereLocalDevRapidAction("economy:bank-upgrade", 650)) {
    return;
  }
  let inventory = readHarthmereInventoryState();
  const cost = 75 + inventory.bank.maxSlots * 4;
  if ((inventory.wallet.gold ?? 0) < cost) {
    writeHarthmereInventoryState(
      appendInventoryLog(
        inventory,
        "Cannot Upgrade Bank",
        `A bank-slot upgrade costs ${cost} gold.`,
      ),
    );
    return;
  }
  inventory = appendInventoryLog(
    {
      ...inventory,
      wallet: {
        ...inventory.wallet,
        gold: (inventory.wallet.gold ?? 0) - cost,
      },
      bank: { ...inventory.bank, maxSlots: inventory.bank.maxSlots + 4 },
    },
    "Bank Upgraded",
    `Bought 4 bank slots for ${cost} gold. Storage upgrades are a safe long-term gold sink.`,
  );
  writeHarthmereInventoryState(inventory);
  recordHarthmereEconomicEvent(
    "sink",
    "Bank Upgrade",
    `Bank space expanded by 4 slots. ${cost} gold left the economy.`,
    -cost,
  );
}

function resetEconomy() {
  writeHarthmereEconomyState(
    appendEconomyLog(
      defaultState(),
      "exchange",
      "Economy Reset",
      "Local-dev economy state reset.",
    ),
  );
}

function averagePrice(itemId: string, state: HarthmereEconomyState) {
  const history = state.priceHistory[itemId] ?? [];
  if (!history.length) {
    return itemData(itemId)?.baseValue ?? 0;
  }
  return Math.round(
    history.reduce((sum, value) => sum + value, 0) / history.length,
  );
}

export function useHarthmereEconomyState() {
  const [state, setState] = useState<HarthmereEconomyState>(() =>
    readHarthmereEconomyState(),
  );

  useEffect(() => {
    const refresh = () => setState(readHarthmereEconomyState());
    const interval = window.setInterval(refresh, 750);
    window.addEventListener("storage", refresh);
    window.addEventListener(HARTHMERE_ECONOMY_EVENT, refresh);
    return () => {
      window.clearInterval(interval);
      window.removeEventListener("storage", refresh);
      window.removeEventListener(HARTHMERE_ECONOMY_EVENT, refresh);
    };
  }, []);

  return state;
}

export function economyActionsForHarthmereNpc(
  offset: number,
): TalkDialogStepAction[] {
  const actions: TalkDialogStepAction[] = [];
  const vendor = VENDOR_PROFILES[offset];

  if (vendor) {
    for (const stock of vendor.sells.slice(0, 3)) {
      const item = itemData(stock.itemId);
      if (!item) {
        continue;
      }
      const quote = vendorPrice(
        vendor,
        stock.itemId,
        stock.quantity,
        "sell_to_player",
      );
      actions.push({
        name: `Economy buy: ${item.name}`,
        tooltip: `${quote} gold after local supply, demand, vendor type, reputation, and legal modifiers.`,
        followUpText: `${vendor.name} quotes ${quote} gold for ${item.name}. Local shortages, reputation, legal standing, and taxes all affect that number.`,
        onPerformed: () => buyEconomyItem(offset, stock.itemId, stock.quantity),
      });
    }
    const firstBuyCategory = vendor.buysCategories[0];
    const sellable = Object.values(ECONOMY_ITEMS).find(
      (item) => item.category === firstBuyCategory,
    );
    if (sellable) {
      const quote = vendorPrice(vendor, sellable.itemId, 1, "buy_from_player");
      actions.push({
        name: `Economy sell: ${sellable.name}`,
        tooltip: `${vendor.name} buys this category. Locked items are protected; materials sell from material storage.`,
        followUpText: `${vendor.name} is buying ${sellable.name} around ${quote} gold each, depending on condition, supply, and your standing.`,
        onPerformed: () => sellEconomyItem(offset, sellable.itemId, 1),
      });
    }
  }

  if ([7, 29, 67].includes(offset)) {
    actions.push({
      name: "Pay repair bill",
      tooltip:
        "Repair equipped gear using economic repair costs instead of the free local-dev repair button.",
      followUpText:
        "The smith checks durability before quoting the bill. Repair fees are a fair gold sink, not a punishment for basic play.",
      onPerformed: () => repairEquippedGearWithEconomy(),
    });
  }

  if ([6, 41].includes(offset)) {
    actions.push({
      name: "Pay Harthmere fine",
      tooltip:
        "If you have negative legal standing, pay a gold fine to repair part of your lawful reputation.",
      followUpText:
        "The clerk checks your legal standing and notoriety before quoting the fine. Paying does not make everyone forget what happened.",
      onPerformed: () => payLegalFine(),
    });
    actions.push({
      name: "Upgrade bank storage",
      tooltip:
        "Buy four more local-dev bank slots. This is a long-term gold sink.",
      onPerformed: () => upgradeBankSpace(),
    });
  }

  if ([34, 65].includes(offset)) {
    actions.push({
      name: "Escort river trade",
      tooltip:
        "Protect the river route. Improves town wealth, supply, security, and reputation.",
      followUpText:
        "A safer river route lowers prices and increases stock. Trade route work is one of the cleanest ways to earn gold.",
      onPerformed: () => escortTradeRoute("river_route"),
    });
    actions.push({
      name: "Smuggle dock cargo",
      tooltip:
        "Illegal but profitable. Adds black-market currency and worsens legal standing.",
      followUpText:
        "The dockhand makes it clear: this avoids tolls and creates profit, but it is not lawful work.",
      onPerformed: () => smuggleRiverCargo(),
    });
  }

  if ([27, 41, 44].includes(offset)) {
    actions.push({
      name: "Escort north caravan",
      tooltip:
        "Guard a lawful trade route. Safer trade increases stock and lowers shortages.",
      onPerformed: () => escortTradeRoute("north_road"),
    });
  }

  if ([41, 6].includes(offset)) {
    actions.push({
      name: "Post first auction item",
      tooltip:
        "Moves the first unlocked, unbound, non-stolen auctionable backpack item into auction escrow and charges a listing fee.",
      followUpText:
        "The market board holds listed goods in escrow. If the listing sells, tax is removed before payout.",
      onPerformed: () => postFirstSellableItemToAuction(),
    });
    actions.push({
      name: "Settle player auction sale",
      tooltip:
        "Simulate the oldest active player listing selling. Pays gold minus sale tax.",
      onPerformed: () => settleOldestPlayerAuction(),
    });
    actions.push({
      name: "Contribute 25g to bridge project",
      tooltip:
        "Town projects are voluntary sinks that change wealth, security, shortages, and services.",
      onPerformed: () => contributeGoldToProject("repair_north_bridge", 25),
    });
    actions.push({
      name: "Contribute iron to bridge project",
      tooltip:
        "Uses Cold Iron Scrap from material storage. Materials should have sinks beyond selling.",
      onPerformed: () =>
        contributeMaterialToProject(
          "repair_north_bridge",
          "cold_iron_scrap",
          4,
        ),
    });
  }

  if ([8, 31, 47, 46].includes(offset)) {
    actions.push({
      name: "Contribute medicine to temple stores",
      tooltip:
        "Uses Fever Tea Bundles and salves from material storage/backpack where available.",
      onPerformed: () =>
        contributeMaterialToProject(
          "stock_temple_medicine",
          "fever_tea_bundle",
          2,
        ),
    });
    actions.push({
      name: "Donate 20g to temple stores",
      tooltip:
        "Improves medicine supply and Likeability through a voluntary local sink.",
      onPerformed: () => contributeGoldToProject("stock_temple_medicine", 20),
    });
  }

  if (BLACK_MARKET_OFFSETS.has(offset)) {
    actions.push({
      name: "Sell stolen goods to fence",
      tooltip:
        "Fences buy stolen goods at a reduced cut. Lawful vendors may refuse or report them.",
      followUpText:
        "The fence checks the mark, not the story. Stolen goods move, but never for full value.",
      onPerformed: () => sellStolenGoodsToFence(),
    });
    actions.push({
      name: "Launder one stolen item",
      tooltip:
        "Pay a fee to remove stolen status from one unlocked backpack item.",
      onPerformed: () => launderStolenItem(),
    });
  }

  if (offset === 41) {
    actions.push({
      name: "Buy auction salves",
      tooltip: "Buy the first active salve listing from the market board.",
      onPerformed: () => {
        const listing = activeListings(readHarthmereEconomyState()).find(
          (entry) => entry.itemId === "minor_healing_salve",
