function normalizeState(
  raw: Partial<HarthmereEconomyState> | undefined,
): HarthmereEconomyState {
  const fallback = defaultState();
  const rawProjects = raw?.town?.activeProjects ?? [];
  const projects = defaultTownProjects().map((project) => {
    const existing = rawProjects.find(
      (candidate) => candidate.id === project.id,
    );
    return existing ? { ...project, ...existing } : project;
  });
  return {
    version: 1,
    town: {
      ...fallback.town,
      ...(raw?.town ?? {}),
      wealth: clamp(Number(raw?.town?.wealth ?? fallback.town.wealth), 0, 100),
      security: clamp(
        Number(raw?.town?.security ?? fallback.town.security),
        0,
        100,
      ),
      crimeRate: clamp(
        Number(raw?.town?.crimeRate ?? fallback.town.crimeRate),
        0,
        100,
      ),
      foodSupply: clamp(
        Number(raw?.town?.foodSupply ?? fallback.town.foodSupply),
        0,
        100,
      ),
      oreSupply: clamp(
        Number(raw?.town?.oreSupply ?? fallback.town.oreSupply),
        0,
        100,
      ),
      medicineSupply: clamp(
        Number(raw?.town?.medicineSupply ?? fallback.town.medicineSupply),
        0,
        100,
      ),
      taxRate: clamp(
        Number(raw?.town?.taxRate ?? fallback.town.taxRate),
        0,
        0.25,
      ),
      tradeRouteStatus: {
        ...fallback.town.tradeRouteStatus,
        ...(raw?.town?.tradeRouteStatus ?? {}),
      },
      activeShortages:
        raw?.town?.activeShortages ?? fallback.town.activeShortages,
      activeSurpluses:
        raw?.town?.activeSurpluses ?? fallback.town.activeSurpluses,
      activeProjects: projects,
    },
    auctionListings: (raw?.auctionListings?.length
      ? raw.auctionListings
      : fallback.auctionListings
    ).slice(0, 20),
    priceHistory: {
      ...fallback.priceHistory,
      ...(raw?.priceHistory ?? {}),
    },
    blackMarketDiscovered:
      raw?.blackMarketDiscovered ?? fallback.blackMarketDiscovered,
    lastQuoteAt: raw?.lastQuoteAt,
    recent: (raw?.recent ?? fallback.recent).slice(0, 16),
  };
}

export function readHarthmereEconomyState(): HarthmereEconomyState {
  if (!isBrowser()) {
    return defaultState();
  }
  try {
    const raw = window.localStorage.getItem(HARTHMERE_ECONOMY_STATE_KEY);
    if (!raw) {
      return defaultState();
    }
    return normalizeState(JSON.parse(raw) as Partial<HarthmereEconomyState>);
  } catch {
    return defaultState();
  }
}

export function writeHarthmereEconomyState(state: HarthmereEconomyState) {
  if (!isBrowser()) {
    return;
  }
  window.localStorage.setItem(
    HARTHMERE_ECONOMY_STATE_KEY,
    JSON.stringify(normalizeState(state)),
  );
  economyEvent();
}

function appendEconomyLog(
  state: HarthmereEconomyState,
  type: EconomyEventType,
  label: string,
  detail: string,
  goldDelta?: number,
) {
  return {
    ...state,
    recent: [logEntry(type, label, detail, goldDelta), ...state.recent].slice(
      0,
      16,
    ),
  };
}

export function recordHarthmereEconomicEvent(
  type: EconomyEventType,
  label: string,
  detail: string,
  goldDelta?: number,
) {
  writeHarthmereEconomyState(
    appendEconomyLog(
      readHarthmereEconomyState(),
      type,
      label,
      detail,
      goldDelta,
    ),
  );
}

