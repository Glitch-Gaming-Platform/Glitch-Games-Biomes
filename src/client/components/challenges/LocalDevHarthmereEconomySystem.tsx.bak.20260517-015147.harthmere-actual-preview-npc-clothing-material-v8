      name: "Reset local-dev economy",
      tooltip:
        "Clears only Harthmere local-dev economy state: prices, listings, projects, supply, routes, and logs.",
      onPerformed: () => resetEconomy(),
    });
  }

  return actions;
}

function percent(value: number) {
  return `${Math.round(value)}%`;
}

function goldLabel(value?: number) {
  if (!value) {
    return "0g";
  }
  return `${value > 0 ? "+" : ""}${value}g`;
}

