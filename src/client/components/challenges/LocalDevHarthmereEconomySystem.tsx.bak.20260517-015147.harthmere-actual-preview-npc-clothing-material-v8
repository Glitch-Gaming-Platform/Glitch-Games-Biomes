function sellStolenGoodsToFence() {
  if (!claimHarthmereLocalDevRapidAction("economy:fence-stolen-goods", 650)) {
    return;
  }
  let inventory = readHarthmereInventoryState();
  let payout = 0;
  const kept: HarthmereItemInstance[] = [];
  for (const item of inventory.backpack.items) {
    const economy = itemData(item.itemId);
    if (item.stolen && economy?.vendorSellable && !item.locked) {
      payout += Math.max(
        1,
        Math.round(economy.baseValue * item.quantity * 0.35),
      );
    } else {
      kept.push(item);
    }
  }
  if (payout <= 0) {
    writeHarthmereInventoryState(
      appendInventoryLog(
        inventory,
        "No Stolen Goods",
        "The fence found no unlocked stolen goods in your backpack.",
      ),
    );
    return;
  }
  inventory = appendInventoryLog(
    {
      ...inventory,
      backpack: { ...inventory.backpack, items: kept },
      wallet: {
        ...inventory.wallet,
        gold: (inventory.wallet.gold ?? 0) + payout,
        black_market_coins: (inventory.wallet.black_market_coins ?? 0) + 1,
      },
    },
    "Fence Sale",
    `Fence bought stolen goods for ${payout} gold and 1 Black Market Coin.`,
  );
  writeHarthmereInventoryState(inventory);
  writeHarthmereEconomyState(
    appendEconomyLog(
      { ...readHarthmereEconomyState(), blackMarketDiscovered: true },
      "black_market",
      "Fence Sale",
      "Stolen goods left your backpack through the black market at a reduced cut.",
      payout,
    ),
  );
}

