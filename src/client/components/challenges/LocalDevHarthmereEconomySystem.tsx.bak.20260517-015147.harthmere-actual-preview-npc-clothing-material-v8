      "warning",
      "Cannot Buy",
      `${vendor.name} quoted ${price} gold for ${item.name} x${quantity}, but you do not have enough gold.`,
    );
    return;
  }
  grantHarthmereItem(itemId, quantity, "Vendor Purchase");
  recordHarthmereEconomicEvent(
    "sink",
    "Vendor Purchase",
    `${vendor.name} sold ${item.name} x${quantity}. Gold left the economy through vendor pricing and local taxes.`,
    -price,
  );
}

function removeBackpackItemForSale(
  state: HarthmereInventoryState,
  itemId: string,
  quantity: number,
): { state: HarthmereInventoryState; removed: number; stolen: boolean } {
  let remaining = quantity;
  let stolen = false;
  const nextItems: HarthmereItemInstance[] = [];
  for (const item of state.backpack.items) {
    if (item.itemId !== itemId || item.locked || remaining <= 0) {
      nextItems.push(item);
      continue;
    }
    const move = Math.min(item.quantity, remaining);
    stolen = stolen || item.stolen;
    remaining -= move;
    if (item.quantity > move) {
      nextItems.push({ ...item, quantity: item.quantity - move });
    }
  }
  return {
    state: { ...state, backpack: { ...state.backpack, items: nextItems } },
    removed: quantity - remaining,
    stolen,
  };
}

function sellEconomyItem(offset: number, itemId: string, quantity: number) {
  if (!claimHarthmereLocalDevRapidAction(`economy:sell:${offset}:${itemId}:${quantity}`, 650)) {
    return;
  }
  const vendor = VENDOR_PROFILES[offset];
  const item = itemData(itemId);
  if (!vendor || !item) {
    return;
  }
  if (!vendor.buysCategories.includes(item.category)) {
    recordHarthmereEconomicEvent(
      "warning",
      "Vendor Refused Item",
      `${vendor.name} does not buy ${item.category.replaceAll("_", " ")} goods.`,
    );
    return;
  }

  let inventory = readHarthmereInventoryState();
  let removed = 0;
  let stolen = false;

  if (item.category === "crafting_material") {
    const available = inventory.materialStorage[itemId] ?? 0;
    removed = Math.min(quantity, available);
    if (removed > 0) {
      inventory = {
        ...inventory,
        materialStorage: {
          ...inventory.materialStorage,
          [itemId]: available - removed,
        },
      };
    }
  } else {
    const result = removeBackpackItemForSale(inventory, itemId, quantity);
    inventory = result.state;
    removed = result.removed;
    stolen = result.stolen;
  }

  if (removed <= 0) {
    writeHarthmereInventoryState(
      appendInventoryLog(
        inventory,
        "Nothing Sold",
        `No unlocked ${item.name} was available to sell.`,
      ),
    );
    return;
  }

  if (stolen && vendor.refusesStolenGoods) {
    writeHarthmereInventoryState(
      appendInventoryLog(
        readHarthmereInventoryState(),
        "Stolen Goods Refused",
        `${vendor.name} refused stolen ${item.name}. Try a fence instead.`,
      ),
    );
    recordHarthmereEconomicEvent(
      "warning",
      "Stolen Goods Refused",
      `${vendor.name} refused stolen goods and may remember the attempt.`,
    );
    return;
  }

  const payout = vendorPrice(vendor, itemId, removed, "buy_from_player");
  inventory = setGold(
    inventory,
    (inventory.wallet.gold ?? 0) + payout,
    "Vendor Sale",
    `${item.name} x${removed} sold to ${vendor.name} for ${payout} gold.`,
  );
  writeHarthmereInventoryState(inventory);
  recordHarthmereEconomicEvent(
    "source",
    "Vendor Sale",
    `${vendor.name} bought ${item.name} x${removed}. Vendor sale created local gold income, but the buy price stayed below base value to avoid infinite loops.`,
    payout,
  );
}

function repairEquippedGearWithEconomy() {
  if (!claimHarthmereLocalDevRapidAction("economy:repair-equipped", 650)) {
    return;
  }
  let inventory = readHarthmereInventoryState();
  let cost = 0;
  const equipment = Object.fromEntries(
    Object.entries(inventory.equipment).map(([slot, item]) => {
      if (!item) {
        return [slot, item];
      }
      const economy = itemData(item.itemId);
      const expectedMax =
        item.itemId === "iron_longsword"
          ? 50
          : item.itemId === "wooden_shield"
            ? 45
            : item.itemId === "training_dagger"
              ? 35
              : (item.durability ?? 40);
      const missing = Math.max(
        0,
        expectedMax - (item.durability ?? expectedMax),
      );
      if (missing > 0) {
        const damagePercent = missing / expectedMax;
        cost += Math.max(
          1,
          Math.round((economy?.baseValue ?? 20) * damagePercent * 0.2),
        );
      }
      return [slot, { ...item, durability: expectedMax }];
    }),
  ) as HarthmereInventoryState["equipment"];

  if (cost <= 0) {
    writeHarthmereInventoryState(
      appendInventoryLog(
        inventory,
        "No Repair Needed",
        "Your equipped gear is already in good condition.",
      ),
    );
    return;
  }
  if ((inventory.wallet.gold ?? 0) < cost) {
    writeHarthmereInventoryState(
      appendInventoryLog(
        inventory,
        "Cannot Repair",
        `Repairs cost ${cost} gold. You have ${inventory.wallet.gold ?? 0}.`,
      ),
    );
    return;
  }
  inventory = setGold(
    { ...inventory, equipment },
    (inventory.wallet.gold ?? 0) - cost,
    "Repaired Gear",
    `Paid ${cost} gold in repair fees. Repairs are a gold sink, but kept moderate for local-dev testing.`,
  );
  writeHarthmereInventoryState(inventory);
  recordHarthmereEconomicEvent(
    "sink",
    "Repair Fees",
    `Black Anvil repairs removed ${cost} gold from the local economy.`,
    -cost,
  );
}

