  if (placement.asset === "townsperson_guard") {
    root.add(
      boxMesh("guard-tabard", [0.4, 0.12, 0.22], [0, 0.9, -0.02], 0x141414),
    );
  } else if (placement.asset === "townsperson_courier") {
    root.add(
      boxMesh(
        "courier-satchel",
        [0.18, 0.18, 0.08],
        [-0.24, 0.7, 0.13],
        0x7a4f2a,
