function createProceduralTownsperson(
  placement: RuntimePlacement,
): THREE.Object3D | undefined {
  if (!isProceduralTownspersonKey(placement.asset)) {
    return undefined;
  }

  const palette = townspersonPalette(placement.asset);
  const root = new THREE.Group();
  root.name = placement.name ?? placement.asset;
  root.position.set(...placement.at);
  root.rotation.y = placement.rot ?? 0;
  root.scale.setScalar(placement.scale ?? 1);

  // Minecraft-style block proportions: feet start on the authored ground and
  // every body part is a rectangular voxel. These are ambient walkers only,
  // not quest givers, so they cannot break dialogue interactions.
  root.add(
    boxMesh(
      "townsperson-left-leg",
      [0.12, 0.42, 0.12],
      [-0.09, 0.21, 0],
      palette.legs,
    ),
    boxMesh(
