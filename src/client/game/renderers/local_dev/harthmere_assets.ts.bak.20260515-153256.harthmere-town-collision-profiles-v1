          new CustomEvent(HARTHMERE_COMBAT_EFFECT_EVENT, {
            detail: {
              attacker: "Road Bandit Scout",
              attackerOffset: 9003,
              target: "You",
              result: "normal_hit",
              finalDamage: 12,
            },
          }),
        );
      },
      fakeBanditHit: () => {
        window.dispatchEvent(
          new CustomEvent(HARTHMERE_COMBAT_EFFECT_EVENT, {
            detail: {
              attacker: "You",
              target: "Road Bandit Scout",
              targetOffset: 9003,
              result: "normal_hit",
              finalDamage: 12,
            },
          }),
        );
      },
      fakeBanditDeath: () => {
        window.dispatchEvent(
          new CustomEvent(HARTHMERE_COMBAT_EFFECT_EVENT, {
            detail: {
