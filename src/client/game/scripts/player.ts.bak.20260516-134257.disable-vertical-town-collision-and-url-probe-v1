const HARTHMERE_LOCAL_DEV_EDGE_SAFE_BOUNDS = {
  minX: -224,
  maxX: 1216,
  minZ: -960,
  maxZ: 480,
  minY: 20,
  maxY: 140,
};

const HARTHMERE_LOCAL_DEV_EDGE_RESCUE_BUFFER = 36;

const HARTHMERE_LOCAL_DEV_PLAYER_TOWN_COLLISION_VERSION =
  "harthmere-player-town-collision-v1";
const HARTHMERE_LOCAL_DEV_PLAYER_TOWN_COLLISION_DISABLED_BY_DEFAULT_V1 = true;
const HARTHMERE_LOCAL_DEV_PLAYER_TOWN_COLLISION_Y_MIN = 50.5;
const HARTHMERE_LOCAL_DEV_PLAYER_TOWN_COLLISION_Y_MAX = 78;
const HARTHMERE_LOCAL_DEV_PLAYER_TOWN_COLLISION_PADDING = 0.18;

type HarthmereLocalDevTownCollisionObstacle = {
  name?: string;
  district?: string;
  cx?: number;
  cz?: number;
  halfX?: number;
  halfZ?: number;
  rot?: number;
  padding?: number;
};

type HarthmereLocalDevTownCollisionBox = {
  name?: string;
  district?: string;
  aabb: AABB;
};

let harthmereLocalDevTownCollisionSource:
  | readonly HarthmereLocalDevTownCollisionObstacle[]
  | undefined;
let harthmereLocalDevTownCollisionBoxes: HarthmereLocalDevTownCollisionBox[] = [];

function harthmereLocalDevAabbIntersects(a: AABB, b: AABB): boolean {
  return (
    a[0][0] <= b[1][0] &&
    a[1][0] >= b[0][0] &&
    a[0][1] <= b[1][1] &&
    a[1][1] >= b[0][1] &&
    a[0][2] <= b[1][2] &&
    a[1][2] >= b[0][2]
  );
}

function shouldUseHarthmereLocalDevTownCollision(aabb: AABB): boolean {
  // Harthmere town collision is driven by renderer-authored obstacles. Those
  // obstacles only exist in the local Harthmere scene, so this bridge must work
  // in dev, production-like local runs, and browser builds. Bounds/obstacle
  // presence protect other Biomes worlds; NODE_ENV must not disable it.
  const [v0, v1] = aabb;
  const { minX, maxX, minZ, maxZ, minY, maxY } =
    HARTHMERE_LOCAL_DEV_EDGE_SAFE_BOUNDS;

  // Only run this local-dev renderer collision bridge inside the authored
  // Harthmere altitude/bounds band. This keeps normal Biomes worlds untouched.
  return !(
    v1[0] < minX ||
    v0[0] > maxX ||
    v1[2] < minZ ||
    v0[2] > maxZ ||
    v1[1] < minY ||
    v0[1] > maxY
  );
}

function harthmereLocalDevTownObstacleToAabb(
  obstacle: HarthmereLocalDevTownCollisionObstacle
): HarthmereLocalDevTownCollisionBox | undefined {
  const cx = Number(obstacle.cx);
  const cz = Number(obstacle.cz);
  const halfX = Number(obstacle.halfX);
  const halfZ = Number(obstacle.halfZ);
  if (
    !Number.isFinite(cx) ||
    !Number.isFinite(cz) ||
    !Number.isFinite(halfX) ||
    !Number.isFinite(halfZ) ||
    halfX <= 0 ||
    halfZ <= 0
  ) {
    return undefined;
  }

  const rot = Number.isFinite(Number(obstacle.rot)) ? Number(obstacle.rot) : 0;
  const padding =
    (Number.isFinite(Number(obstacle.padding)) ? Number(obstacle.padding) : 0) +
    HARTHMERE_LOCAL_DEV_PLAYER_TOWN_COLLISION_PADDING;
  const c = Math.abs(Math.cos(rot));
  const s = Math.abs(Math.sin(rot));
  const worldHalfX = c * halfX + s * halfZ + padding;
  const worldHalfZ = s * halfX + c * halfZ + padding;

  return {
    name: obstacle.name,
    district: obstacle.district,
    aabb: [
      [cx - worldHalfX, HARTHMERE_LOCAL_DEV_PLAYER_TOWN_COLLISION_Y_MIN, cz - worldHalfZ],
      [cx + worldHalfX, HARTHMERE_LOCAL_DEV_PLAYER_TOWN_COLLISION_Y_MAX, cz + worldHalfZ],
    ],
  };
}

function getHarthmereLocalDevTownCollisionBoxes(): HarthmereLocalDevTownCollisionBox[] {
  const globalScope = globalThis as unknown as {
    __harthmereNpcCollisionObstacles?: readonly HarthmereLocalDevTownCollisionObstacle[];
    window?: {
      __harthmereNpcCollisionObstacles?: readonly HarthmereLocalDevTownCollisionObstacle[];
      __harthmereDisablePlayerTownCollision?: boolean;
    };
  };
  const browserWindow = globalScope.window;
  if (browserWindow?.__harthmereDisablePlayerTownCollision) {
    return [];
  }

  const obstacles =
    browserWindow?.__harthmereNpcCollisionObstacles ??
    globalScope.__harthmereNpcCollisionObstacles;
  if (!Array.isArray(obstacles)) {
    return [];
  }

  if (harthmereLocalDevTownCollisionSource !== obstacles) {
    harthmereLocalDevTownCollisionSource = obstacles;
    harthmereLocalDevTownCollisionBoxes = obstacles
      .map(harthmereLocalDevTownObstacleToAabb)
      .filter(
        (box): box is HarthmereLocalDevTownCollisionBox => Boolean(box)
      );
  }

  return harthmereLocalDevTownCollisionBoxes;
}


function markHarthmereLocalDevTownCollisionDisabledByDefault() {
  const globalScope = globalThis as unknown as {
    window?: {
      __harthmerePlayerTownCollisionStats?: Record<string, unknown>;
    };
  };
  const statsTarget = globalScope.window;
  if (!statsTarget) {
    return;
  }
  statsTarget.__harthmerePlayerTownCollisionStats = {
    ...(statsTarget.__harthmerePlayerTownCollisionStats ?? {}),
    version: HARTHMERE_LOCAL_DEV_PLAYER_TOWN_COLLISION_VERSION,
    disabledByDefaultVersion:
      HARTHMERE_LOCAL_DEV_PLAYER_TOWN_COLLISION_DISABLED_BY_DEFAULT_V1,
    enabled: false,
    reason:
      "Disabled by default after vertical AABB solver push/floating issue. Set window.__harthmereEnablePlayerTownCollision = true only for targeted testing.",
  };
}

function intersectLocalDevHarthmereTownCollision(
  aabb: AABB,
  fn: CollisionCallback
) {
  if (!shouldUseHarthmereLocalDevTownCollision(aabb)) {
    return;
  }

  const boxes = getHarthmereLocalDevTownCollisionBoxes();
  if (!boxes.length) {
    return;
  }

  let tested = 0;
  let hits = 0;
  const hitNames: string[] = [];
  for (const box of boxes) {
    tested += 1;
    if (!harthmereLocalDevAabbIntersects(aabb, box.aabb)) {
      continue;
    }
    hits += 1;
    if (hitNames.length < 8) {
      hitNames.push(box.name ?? "unnamed Harthmere obstacle");
    }
    if (fn(box.aabb)) {
      break;
    }
  }

  const globalScope = globalThis as unknown as {
    __harthmerePlayerTownCollisionStats?: Record<string, unknown>;
    window?: {
      __harthmerePlayerTownCollisionStats?: Record<string, unknown>;
    };
  };
  const statsTarget = globalScope.window ?? globalScope;
  const previous = statsTarget.__harthmerePlayerTownCollisionStats ?? {};
  statsTarget.__harthmerePlayerTownCollisionStats = {
    ...previous,
    version: HARTHMERE_LOCAL_DEV_PLAYER_TOWN_COLLISION_VERSION,
    enabled: true,
    obstacleCount: boxes.length,
    queries: Number(previous.queries ?? 0) + 1,
    hitsTotal: Number(previous.hitsTotal ?? 0) + hits,
    lastQueryAt: Date.now(),
    lastQueryAabb: aabb,
    lastTested: tested,
    lastHitCount: hits,
    lastHitNames: hitNames,
  };
}


function maybeClampLocalDevHarthmereEdgePosition(position: ReadonlyVec3): Vec3 {
  if (process.env.NODE_ENV === "production") {
    return [...position];
  }

  const { minX, maxX, minZ, maxZ, minY, maxY } =
    HARTHMERE_LOCAL_DEV_EDGE_SAFE_BOUNDS;
  const [x, y, z] = position;

  // Only touch the authored Harthmere local-dev altitude band. This avoids
  // changing unrelated test worlds while preventing the player from stepping
  // into missing edge terrain and getting wedged by the movement solver.
  if (y < minY || y > maxY) {
    return [...position];
  }

  let safeX = x;
  let safeZ = z;
  if (x <= minX) {
    safeX = minX + HARTHMERE_LOCAL_DEV_EDGE_RESCUE_BUFFER;
  } else if (x >= maxX) {
    safeX = maxX - HARTHMERE_LOCAL_DEV_EDGE_RESCUE_BUFFER;
  }
  if (z <= minZ) {
    safeZ = minZ + HARTHMERE_LOCAL_DEV_EDGE_RESCUE_BUFFER;
  } else if (z >= maxZ) {
    safeZ = maxZ - HARTHMERE_LOCAL_DEV_EDGE_RESCUE_BUFFER;
  }

  return [safeX, y, safeZ];
}


