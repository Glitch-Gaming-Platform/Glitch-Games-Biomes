    faceConfig?.skinTone === "metal";

  const faceShape = faceConfig?.faceShape ?? pickLocalDev(HARTHMERE_FACE_SHAPES_FALLBACK, seed, 4);
  const headWidth = robot
    ? 0.36
    : faceShape === "wide"
    ? 0.38
    : faceShape === "narrow"
