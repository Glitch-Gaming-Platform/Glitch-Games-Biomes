function canonicalizeHarthmereBuilderAlias(value: string) {
  return value
    .trim()
    .replace(/([a-z0-9])([A-Z])/g, "$1_$2")
    .replace(/[^a-zA-Z0-9]+/g, "_")
    .replace(/^_|_$/g, "")
    .toLowerCase();
}

export function canonicalizeHarthmereAppearanceBuilderField(
  field: string,
): HarthmereAppearanceBuilderField | undefined {
  if ((HARTHMERE_APPEARANCE_BUILDER_FIELDS as readonly string[]).includes(field)) {
    return field as HarthmereAppearanceBuilderField;
  }
  return HARTHMERE_APPEARANCE_BUILDER_FIELD_ALIASES[
    canonicalizeHarthmereBuilderAlias(field)
  ];
}

export function isHarthmereAppearanceBuilderFaceField(
  field: string,
): field is HarthmereAppearanceBuilderFaceField {
  return (HARTHMERE_APPEARANCE_BUILDER_FACE_FIELDS as readonly string[]).includes(field);
}

export function isHarthmereAppearanceBuilderBodyField(
  field: string,
): field is HarthmereAppearanceBuilderBodyField {
  return (HARTHMERE_APPEARANCE_BUILDER_BODY_FIELDS as readonly string[]).includes(field);
}

export function applyHarthmereAppearanceBuilderSelection(input: {
  face: Partial<HarthmereVoxelFaceConfig> | undefined;
  body: Partial<HarthmereVoxelBodyConfig> | undefined;
  field: HarthmereAppearanceBuilderField | string;
  value: string;
}): {
  face: HarthmereVoxelFaceConfig;
  body: HarthmereVoxelBodyConfig;
  applied: boolean;
  target?: "face" | "body";
  canonicalField?: HarthmereAppearanceBuilderField;
} {
  const canonicalField = canonicalizeHarthmereAppearanceBuilderField(input.field);
  const face = normalizeHarthmereFaceConfig(input.face);
  const body = normalizeHarthmereBodyConfig(input.body);

  if (!canonicalField) {
    return { face, body, applied: false };
  }

  if (isHarthmereAppearanceBuilderFaceField(canonicalField)) {
    const nextFace = normalizeHarthmereFaceConfig({
      ...face,
      [canonicalField]: input.value,
    });
    // Gender has a dependent default pronoun. Only auto-change pronouns when the
    // user changed gender itself; direct Pronouns/Custom Pronouns choices must
    // not be overwritten by this mapping layer.
    if (canonicalField === "genderIdentity") {
      nextFace.pronouns = defaultPronounsForGender(nextFace.genderIdentity);
    }
    return {
      face: nextFace,
      body,
      applied: true,
      target: "face",
      canonicalField,
    };
  }

  const nextBody = normalizeHarthmereBodyConfig({
    ...body,
    [canonicalField]: input.value,
  });
  return {
    face,
    body: nextBody,
    applied: true,
    target: "body",
    canonicalField,
  };
}

export function applyHarthmereAppearanceBuilderSelectionToAppearance(input: {
  appearance: HarthmereCharacterAppearanceInput | HarthmereCharacterAppearance;
  field: HarthmereAppearanceBuilderField | string;
  value: string;
}): HarthmereCharacterAppearance {
  const appearance = normalizeHarthmereCharacterAppearance(input.appearance);
  const result = applyHarthmereAppearanceBuilderSelection({
    face: appearance.face,
    body: appearance.body,
    field: input.field,
    value: input.value,
  });
  // This helper is intentionally appearance-level, not player-specific. Use it
  // for player previews, saved player configs, generated NPCs, and debug tools
  // whenever a selection should update the same canonical face/body field.
  return normalizeHarthmereCharacterAppearance({
    ...appearance,
    face: result.face,
    body: result.body,
  });
}

export function auditHarthmereAppearanceBuilderFieldMappings() {
  const defaults = normalizeHarthmereCharacterAppearance({
    species: "human",
    role: "player",
    face: DEFAULT_HARTHMERE_PLAYER_FACE,
    body: DEFAULT_HARTHMERE_PLAYER_BODY,
  });
  return HARTHMERE_APPEARANCE_BUILDER_FIELDS.map((field) => {
    const options = isHarthmereAppearanceBuilderFaceField(field)
      ? HARTHMERE_APPEARANCE_BUILDER_FACE_FIELDS
      : HARTHMERE_APPEARANCE_BUILDER_BODY_FIELDS;
    const result = applyHarthmereAppearanceBuilderSelectionToAppearance({
      appearance: defaults,
      field,
      value: field === "customPronouns" ? "fae/faer" : String((options as readonly string[])[0] ?? ""),
    });
    return {
      field,
      canonicalField: canonicalizeHarthmereAppearanceBuilderField(field),
      target: isHarthmereAppearanceBuilderFaceField(field) ? "face" : "body",
      playerValue:
        isHarthmereAppearanceBuilderFaceField(field)
          ? result.face[field]
          : result.body[field],
      npcValue:
        isHarthmereAppearanceBuilderFaceField(field)
          ? applyHarthmereAppearanceBuilderSelectionToAppearance({
              appearance: makeHarthmereNpcAppearanceConfig({ id: 1, name: "Audit NPC" }),
              field,
              value: field === "customPronouns" ? "fae/faer" : String((options as readonly string[])[0] ?? ""),
            }).face[field]
          : applyHarthmereAppearanceBuilderSelectionToAppearance({
              appearance: makeHarthmereNpcAppearanceConfig({ id: 1, name: "Audit NPC" }),
              field,
              value: String((options as readonly string[])[0] ?? ""),
            }).body[field],
    };
  });
}

