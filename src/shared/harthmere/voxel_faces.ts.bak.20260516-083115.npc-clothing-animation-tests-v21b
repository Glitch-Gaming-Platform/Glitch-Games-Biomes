  if (role === "merchant") {
    return {
      ...common,
      torso: harthmereThreeJsClothingItem("merchant_coat"),
      feet: harthmereThreeJsClothingItem("soft_shoes"),
      back: harthmereThreeJsClothingItem("merchant_satchel"),
      belt: harthmereThreeJsClothingItem("ledger_belt"),
