export function pickHarthmereAttackVariationV13(
  family: HarthmereAttackFamilyV13,
  history: readonly string[],
  preferredSide?: "left" | "right" | "center",
): HarthmereAttackVariationV13 {
  const variants = HARTHMERE_ATTACK_VARIATIONS_V13[family];
  const last = history[history.length - 1];
  const prior = history[history.length - 2];
  const candidates = variants.filter((variant) => variant.id !== last && variant.id !== prior);
  const sided = preferredSide
    ? candidates.filter((variant) => variant.attackSide === preferredSide)
    : candidates;
  const pool = sided.length ? sided : candidates.length ? candidates : variants.filter((v) => v.id !== last);
  return pool[0] || variants[0];
}
