  id: string;
  version: typeof HARTHMERE_COMBAT_ANIMATION_POLISH_VERSION_V1;
  category: "weapon" | "magic";
  shape: string;
  theme: HarthmereAttackVisualThemeIdV1;
  frameCount: number;
  fps: number;
  impactFrame: number;
  sampleFrames: readonly number[];
  bodyMotion: string;
  mainHand: "left" | "right" | "both" | "caster";
  offhandMotion: string;
  weaponPath: string;
  trailShape: string;
  silhouette: string;
  color: number;
  secondaryColor: number;
  particleStyle: string;
  playerAndNpcShared: true;
  noColorOnlyVariation: true;
  mainHandGripMaxDistanceMeters: 0.12;
  bladeLagMaxDistanceMeters: 0.16;
