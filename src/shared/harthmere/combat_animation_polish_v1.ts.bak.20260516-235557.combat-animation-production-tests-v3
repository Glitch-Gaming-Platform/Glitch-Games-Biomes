export type HarthmereCombatAttackTypeV2 = "basic" | "heavy" | "magic";

function harthmereCombatAnimationVariationHashV2(input: string) {
  let hash = 2166136261;
  for (let i = 0; i < input.length; i += 1) {
    hash ^= input.charCodeAt(i);
    hash = Math.imul(hash, 16777619);
  }
  return hash >>> 0;
}

export function harthmereCombatAnimationProfileForRandomizedActionV2(options: {
  attackType?: HarthmereCombatAttackTypeV2;
  seed?: number | string;
  theme?: HarthmereAttackVisualThemeIdV1;
  lastShape?: string;
  requestedShape?: string;
}) {
  const attackType = options.attackType ?? "basic";
  const themeId = options.theme ?? "physical";
  const sequence = attackType === "magic"
    ? magicSequence
    : attackType === "heavy"
      ? heavyWeaponSequence
      : basicWeaponSequence;
  const requested = options.requestedShape?.trim();
  let shape = requested && (sequence as readonly string[]).includes(requested)
    ? requested
    : undefined;
  if (!shape) {
    const seedNumber = typeof options.seed === "number"
      ? Math.abs(Math.floor(options.seed))
      : harthmereCombatAnimationVariationHashV2(String(options.seed ?? `${Date.now()}-${Math.random()}`));
    let index = seedNumber % sequence.length;
    if (options.lastShape === sequence[index] && sequence.length > 1) {
      index = (index + 1 + (seedNumber % (sequence.length - 1))) % sequence.length;
      if (options.lastShape === sequence[index]) {
        index = (index + 1) % sequence.length;
      }
    }
    shape = sequence[index];
  }
  return HARTHMERE_ATTACK_ANIMATION_PROFILES_V1.find(
    (profile) => profile.shape === shape && profile.theme === themeId,
  ) ?? harthmereCombatAnimationProfileForActionV1({
    category: attackType === "magic" ? "magic" : "weapon",
    heavy: attackType === "heavy",
    index: 0,
    theme: themeId,
  });
}

export function harthmereCombatAnimationProfileForActionV1(options: {
  category?: "weapon" | "magic";
  heavy?: boolean;
  index?: number;
  theme?: HarthmereAttackVisualThemeIdV1;
}) {
  const themeId = options.theme ?? "physical";
  const index = Math.max(0, Math.floor(options.index ?? 0));
  const shape = options.category === "magic"
    ? magicSequence[index % magicSequence.length]
    : options.heavy
      ? heavyWeaponSequence[index % heavyWeaponSequence.length]
      : basicWeaponSequence[index % basicWeaponSequence.length];
  return HARTHMERE_ATTACK_ANIMATION_PROFILES_V1.find(
    (profile) => profile.shape === shape && profile.theme === themeId,
  ) ?? HARTHMERE_ATTACK_ANIMATION_PROFILES_V1[0];
}

export function harthmereCombatAnimationPhaseForFrameV1(frame: number) {
  if (frame <= 4) return "windup";
  if (frame <= 8) return "anticipation";
  if (frame <= 12) return "release";
  if (frame <= 15) return "impact";
  if (frame <= 20) return "followThrough";
  return "recover";
}
