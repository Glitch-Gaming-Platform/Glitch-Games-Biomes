};

const themeById = new Map(HARTHMERE_ATTACK_VISUAL_THEMES_V1.map((theme) => [theme.id, theme]));

function theme(themeId: HarthmereAttackVisualThemeIdV1) {
  return themeById.get(themeId) ?? HARTHMERE_ATTACK_VISUAL_THEMES_V1[0];
}

function makeWeaponProfile(
  shape: typeof HARTHMERE_WEAPON_ATTACK_SHAPES_V1[number],
  themeId: HarthmereAttackVisualThemeIdV1,
): HarthmereCombatAnimationProfileV1 {
  const t = theme(themeId);
  return {
    id: `${shape.id}_${themeId}`,
    version: HARTHMERE_COMBAT_ANIMATION_POLISH_VERSION_V1,
    category: "weapon",
    shape: shape.id,
    theme: themeId,
    frameCount: HARTHMERE_COMBAT_ANIMATION_FRAME_COUNT_V1,
    fps: HARTHMERE_COMBAT_ANIMATION_FPS_V1,
    impactFrame: shape.impactFrame,
    sampleFrames: shape.sampleFrames,
    bodyMotion: shape.bodyMotion,
    mainHand: shape.id === "slam_ground" || shape.id === "slash_vertical" ? "both" : "left",
    offhandMotion: shape.offhandCounterMotion,
    weaponPath: shape.mainHandPath,
    trailShape: shape.trailShape,
    silhouette: shape.hitSilhouette,
    color: t.color,
    secondaryColor: t.secondary,
    particleStyle: t.particle,
    playerAndNpcShared: true,
    noColorOnlyVariation: true,
    mainHandGripMaxDistanceMeters: 0.12,
    bladeLagMaxDistanceMeters: 0.16,
    locomotionHandFollow: true,
    mechanicInvariant: {
      damageChangedByVisual: false,
      rangeChangedByVisual: false,
      cooldownChangedByVisual: false,
      hitboxChangedByVisual: false,
      resourceCostChangedByVisual: false,
    },
  };
}

