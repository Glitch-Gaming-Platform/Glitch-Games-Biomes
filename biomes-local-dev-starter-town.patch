+    return false;
+  }
+  const [doorX, doorZ] = doorCenter(building);
+  if (building.doorSide === "north" || building.doorSide === "south") {
+    return worldZ === doorZ && Math.abs(worldX - doorX) <= 1;
+  }
+  return worldX === doorX && Math.abs(worldZ - doorZ) <= 1;
