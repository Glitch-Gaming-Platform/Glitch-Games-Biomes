+  }
+  if (hash % 97 === 0) {
+    return materials.rose;
+  }
+  if (hash % 53 === 0) {
+    return materials.dandelion;
+  }
+  if (hash % 17 === 0) {
+    return materials.switchGrass;
+  }
+  return undefined;
