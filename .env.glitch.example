# Harthmere / Biomes Glitch runtime env.
# Copy to your deployment secret/env config. Do not commit real tokens.

GLITCH_TITLE_ID=42de534c-600f-4228-af9e-b69faef94cce
GLITCH_TITLE_TOKEN=replace-with-runtime-secret
GLITCH_API_BASE_URL=https://api.glitch.fun/api

# The Biomes web target listens on 3000 through ./b run.
PORT=3000
WEB_PORT=3000

NODE_ENV=production
NODE_OPTIONS=--openssl-legacy-provider --enable-source-maps
NEXT_TELEMETRY_DISABLED=1
IS_SERVER=true

# Local-data Harthmere mode. These keep the restored fork from trying to fetch
# the original dead upstream production snapshot.
SKIP_PROD_LOAD=true
SKIP_MISSING_ASSET_CHECK=true
BIOMES_FORCE_LOCAL_DEV_TOWN=1
