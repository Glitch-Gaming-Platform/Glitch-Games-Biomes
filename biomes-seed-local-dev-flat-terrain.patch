+const LOCAL_DEV_TERRAIN_ID_BASE = 8_800_000_000_000_000 as BiomesId;
+
+function shouldSeedLocalDevTerrain() {
+  return (
+    process.env.NODE_ENV !== "production" &&
+    process.env.BIOMES_CREATE_LOCAL_DEV_TERRAIN !== "0"
+  );
+}
+
+function hasTerrainShard(service: ShimWorldService) {
+  for (const entity of service.table.contents()) {
+    if (
+      entity.box &&
+      entity.shard_seed &&
+      entity.shard_diff &&
+      entity.shard_shapes
+    ) {
+      return true;
+    }
+  }
+  return false;
+}
+
+function makeLocalDevTerrainShard(
+  voxeloo: VoxelooModule,
+  id: BiomesId,
+  shardX: number,
+  shardY: number,
+  shardZ: number,
+  tick: number
+): Change {
+  const v0 = shardToVoxelPos(shardX, shardY, shardZ);
+  const v1 = [v0[0] + SHARD_DIM, v0[1] + SHARD_DIM, v0[2] + SHARD_DIM] as [
+    number,
+    number,
+    number,
+  ];
+
+  const dirt = getTerrainID("dirt");
+  const grass = getTerrainID("grass");
+
+  const buffer = using(new voxeloo.VolumeBlock_U32(), (seedBlock) => {
+    // The committed local snapshot only contains a tiny ECS bootstrap. It does
+    // not include the historical Biomes terrain shards, so new players have
+    // nothing to stand on. Seed a simple, flat, local-only platform around the
+    // default player start positions. Full production/dev snapshots already
+    // have terrain and will skip this path.
+    for (let z = 0; z < SHARD_DIM; z += 1) {
+      for (let x = 0; x < SHARD_DIM; x += 1) {
+        for (let y = 0; y < 23; y += 1) {
+          seedBlock.set(x, y, z, y === 22 ? grass : dirt);
+        }
+      }
+    }
+    return saveBlock(voxeloo, seedBlock);
+  });
+
+  return {
+    kind: "create",
+    tick,
+    entity: {
+      id,
+      box: Box.create({ v0, v1 }),
+      shard_seed: ShardSeed.create({ buffer }),
+      shard_diff: ShardDiff.create(),
+      shard_shapes: ShardShapes.create(),
+    },
+  };
+}
+
+async function seedLocalDevTerrainIfMissing(service: ShimWorldService) {
+  if (!shouldSeedLocalDevTerrain() || hasTerrainShard(service)) {
+    return;
+  }
+
+  const voxeloo = await loadVoxeloo();
+  const changes: Change[] = [];
+  let idOffset = 0;
+  const tick = service.table.tick + 1;
+
+  // Default player starts are near x=[477..491], y=[53..55], z=[-211..-205].
+  // These shards create a 128x128 platform with the top surface at y=55.
+  for (let shardX = 13; shardX <= 16; shardX += 1) {
+    for (let shardZ = -8; shardZ <= -5; shardZ += 1) {
+      changes.push(
+        makeLocalDevTerrainShard(
+          voxeloo,
+          (LOCAL_DEV_TERRAIN_ID_BASE + idOffset++) as BiomesId,
+          shardX,
+          1,
+          shardZ,
+          tick
+        )
+      );
+    }
+  }
+
+  service.writeableTable.apply(changes);
+  log.warn("Seeded local dev flat terrain platform", {
+    shards: changes.length,
+    topY: 55,
+  });
+}
